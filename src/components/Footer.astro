---
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

// Load configuration
const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));

const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer style="background-color: #1a2d19;" class="text-white">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Company Info -->
      <div class="lg:col-span-1">
        <div class="flex items-center space-x-3 mb-5">
          <img
            src={`${base}assets/fc4d1e14-254e-4b76-be45-d60c4aeea6ea.jpg`}
            alt={`${config.site.title} logo`}
            class="h-12 w-12 rounded-full object-cover shadow-sm"
            width="48"
            height="48"
          />
          <div class="flex flex-col">
            <span class="text-lg font-bold text-white leading-tight" style="font-family: 'Cormorant Garamond', Georgia, serif;">{config.site.title}</span>
            <span class="text-[10px] text-green-400 font-medium uppercase tracking-widest">Landscaping & Growing</span>
          </div>
        </div>
        <p class="text-green-300 text-sm leading-relaxed mb-6">
          Smithers, BC's hands-on landscaping and growing company. Rooted in the Bulkley Valley, growing beautiful spaces one project at a time.
        </p>
        <!-- Trust Badges -->
        <div class="flex flex-wrap gap-2">
          <div class="flex items-center gap-1.5 text-xs text-green-300 px-3 py-1.5 rounded-full" style="background-color: rgba(255,255,255,0.08);">
            <svg class="w-3.5 h-3.5" style="color: #c8a96e;" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            BC Based
          </div>
          <div class="flex items-center gap-1.5 text-xs text-green-300 px-3 py-1.5 rounded-full" style="background-color: rgba(255,255,255,0.08);">
            <svg class="w-3.5 h-3.5" style="color: #c8a96e;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            Eco-Conscious
          </div>
          <div class="flex items-center gap-1.5 text-xs text-green-300 px-3 py-1.5 rounded-full" style="background-color: rgba(255,255,255,0.08);">
            <svg class="w-3.5 h-3.5" style="color: #c8a96e;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            Satisfaction Guaranteed
          </div>
          <div class="flex items-center gap-1.5 text-xs text-green-300 px-3 py-1.5 rounded-full" style="background-color: rgba(255,255,255,0.08);">
            <svg class="w-3.5 h-3.5" style="color: #c8a96e;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Free Estimates
          </div>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-green-400 mb-4">Services</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href={`${base}services/`} class="text-green-300 transition-colors" style="hover-color: #c8a96e;" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color=''">Landscape Installation</a>
          </li>
          <li>
            <a href={`${base}services/`} class="text-green-300 transition-colors" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color=''">Lawn Care & Maintenance</a>
          </li>
          <li>
            <a href={`${base}services/`} class="text-green-300 transition-colors" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color=''">Patio & Hardscaping</a>
          </li>
          <li>
            <a href={`${base}services/`} class="text-green-300 transition-colors" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color=''">Plant Starts & Seedlings</a>
          </li>
          <li>
            <a href={`${base}services/`} class="text-green-300 transition-colors" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color=''">Yard Cleanup</a>
          </li>
          <li>
            <a href={`${base}services/`} class="text-green-300 transition-colors" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color=''">Commercial Landscaping</a>
          </li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-green-400 mb-4">Company</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href={base} class="text-green-300 transition-colors" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color=''">Home</a>
          </li>
          <li>
            <a href={`${base}about/`} class="text-green-300 transition-colors" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color=''">About Us</a>
          </li>
          <li>
            <a href={`${base}services/`} class="text-green-300 transition-colors" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color=''">Services</a>
          </li>
          <li>
            <a href={`${base}gallery/`} class="text-green-300 transition-colors" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color=''">Gallery</a>
          </li>
          {config.features.blog && (
            <li>
              <a href={`${base}blog/`} class="text-green-300 transition-colors" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color=''">Blog</a>
            </li>
          )}
          <li>
            <a href={`${base}contact/`} class="text-green-300 transition-colors" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color=''">Contact</a>
          </li>
          {config.features.faq && (
            <li>
              <a href={`${base}faq/`} class="text-green-300 transition-colors" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color=''">FAQ</a>
            </li>
          )}
          <li>
            <a href={`${base}privacy/`} class="text-green-300 transition-colors" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color=''">Privacy Policy</a>
          </li>
          <li>
            <a href={`${base}terms/`} class="text-green-300 transition-colors" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color=''">Terms of Service</a>
          </li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-green-400 mb-4">Contact Us</h3>
        <div class="space-y-4 text-sm">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: #c8a96e;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-green-300">Smithers, BC, Canada</span>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" style="color: #c8a96e;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${config.contact.phone}`} class="text-green-300 hover:text-white transition-colors font-medium">
              {config.contact.phone}
            </a>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" style="color: #c8a96e;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${config.contact.email}`} class="text-green-300 hover:text-white transition-colors break-all">
              {config.contact.email}
            </a>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" style="color: #c8a96e;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-green-300">{config.contact.businessHours}</span>
          </div>
        </div>

        <!-- Social Links -->
        <div class="flex gap-3 mt-6">
          {config.social.facebook && (
            <a
              href={config.social.facebook}
              class="w-9 h-9 rounded-full flex items-center justify-center text-green-300 hover:text-white transition-all"
              style="background-color: rgba(255,255,255,0.08);"
              aria-label="Facebook"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
              </svg>
            </a>
          )}
          {config.social.instagram && (
            <a
              href={config.social.instagram}
              class="w-9 h-9 rounded-full flex items-center justify-center text-green-300 hover:text-white transition-all"
              style="background-color: rgba(255,255,255,0.08);"
              aria-label="Instagram"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
          )}
        </div>
      </div>
    </div>
  </div>

  <!-- Service Area Bar -->
  <div style="border-top: 1px solid rgba(255,255,255,0.1);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <div class="text-center">
        <h3 class="text-xs font-bold uppercase tracking-wider text-green-400 mb-3">Proudly Serving</h3>
        <p class="text-sm text-green-300">
          Smithers | Telkwa | Houston | Burns Lake | Hazelton | Terrace
        </p>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div style="border-top: 1px solid rgba(255,255,255,0.1);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col md:flex-row justify-between items-center text-xs text-green-400">
      <p>&copy; {currentYear} Metta Growing. All rights reserved. Smithers, BC, Canada.</p>
      <div class="flex gap-6 mt-3 md:mt-0">
        <a href={`${base}privacy/`} class="hover:text-white transition-colors">Privacy</a>
        <a href={`${base}terms/`} class="hover:text-white transition-colors">Terms</a>
        <a href={`${base}faq/`} class="hover:text-white transition-colors">FAQ</a>
      </div>
    </div>
  </div>
</footer>
