---
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';
import Breadcrumbs from './Breadcrumbs.astro';

// Load configuration
const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<header class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <div class="flex items-center">
        <a href={base} class="flex items-center space-x-2" aria-label="Home">
          <img
            src={`${base}assets/logo.svg`}
            alt={`${config.site.title} logo`}
            class="h-8 w-auto"
            width="32"
            height="32"
          />
          <span class="text-xl font-bold text-gray-900">{config.site.title}</span>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex space-x-8" aria-label="Main navigation">
        <ul class="flex space-x-8" role="menubar">
          <li role="none">
            <a
              href={base}
              class={`text-gray-700 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors ${currentPath === base || currentPath === base.slice(0, -1) ? 'text-blue-600 border-b-2 border-blue-600' : ''}`}
              role="menuitem"
              aria-current={currentPath === base || currentPath === base.slice(0, -1) ? 'page' : undefined}
            >
              Home
            </a>
          </li>
          <li role="none">
            <a
              href={`${base}about`}
              class={`text-gray-700 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors ${currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'text-blue-600 border-b-2 border-blue-600' : ''}`}
              role="menuitem"
              aria-current={currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'page' : undefined}
            >
              About
            </a>
          </li>
          {config.features.products && (
            <li role="none">
              <a
                href={`${base}products`}
                class={`text-gray-700 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors ${currentPath.includes('/products') ? 'text-blue-600 border-b-2 border-blue-600' : ''}`}
                role="menuitem"
                aria-current={currentPath.includes('/products') ? 'page' : undefined}
              >
                Products
              </a>
            </li>
          )}
          {config.features.blog && (
            <li role="none">
              <a
                href={`${base}blog`}
                class={`text-gray-700 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors ${currentPath.includes('/blog') ? 'text-blue-600 border-b-2 border-blue-600' : ''}`}
                role="menuitem"
                aria-current={currentPath.includes('/blog') ? 'page' : undefined}
              >
                Blog
              </a>
            </li>
          )}
          <li role="none">
            <a
              href={`${base}contact`}
              class={`text-gray-700 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors ${currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'text-blue-600 border-b-2 border-blue-600' : ''}`}
              role="menuitem"
              aria-current={currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'page' : undefined}
            >
              Contact
            </a>
          </li>
        </ul>
      </nav>

      <!-- Mobile menu button -->
      <div class="md:hidden">
        <button
          type="button"
          class="text-gray-700 hover:text-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 p-2"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle mobile menu"
          id="mobile-menu-button"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div class="md:hidden hidden" id="mobile-menu">
      <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3 bg-white border-t border-gray-200">
        <a
          href={base}
          class={`block px-3 py-2 text-base font-medium text-gray-700 hover:text-blue-600 hover:bg-gray-50 ${currentPath === base || currentPath === base.slice(0, -1) ? 'text-blue-600 bg-blue-50' : ''}`}
          aria-current={currentPath === base || currentPath === base.slice(0, -1) ? 'page' : undefined}
        >
          Home
        </a>
        <a
          href={`${base}about`}
          class={`block px-3 py-2 text-base font-medium text-gray-700 hover:text-blue-600 hover:bg-gray-50 ${currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'text-blue-600 bg-blue-50' : ''}`}
          aria-current={currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'page' : undefined}
        >
          About
        </a>
        {config.features.products && (
          <a
            href={`${base}products`}
            class={`block px-3 py-2 text-base font-medium text-gray-700 hover:text-blue-600 hover:bg-gray-50 ${currentPath.includes('/products') ? 'text-blue-600 bg-blue-50' : ''}`}
            aria-current={currentPath.includes('/products') ? 'page' : undefined}
          >
            Products
          </a>
        )}
        {config.features.blog && (
          <a
            href={`${base}blog`}
            class={`block px-3 py-2 text-base font-medium text-gray-700 hover:text-blue-600 hover:bg-gray-50 ${currentPath.includes('/blog') ? 'text-blue-600 bg-blue-50' : ''}`}
            aria-current={currentPath.includes('/blog') ? 'page' : undefined}
          >
            Blog
          </a>
        )}
        <a
          href={`${base}contact`}
          class={`block px-3 py-2 text-base font-medium text-gray-700 hover:text-blue-600 hover:bg-gray-50 ${currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'text-blue-600 bg-blue-50' : ''}`}
          aria-current={currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'page' : undefined}
        >
          Contact
        </a>
      </div>
    </div>
  </div>

  <!-- Breadcrumbs (for non-home pages) -->
  {currentPath !== base && currentPath !== base.slice(0, -1) && <Breadcrumbs />}
</header>

<script>
  // Mobile menu toggle
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  if (mobileMenuButton && mobileMenu) {
    mobileMenuButton.addEventListener('click', () => {
      const isExpanded = mobileMenuButton.getAttribute('aria-expanded') === 'true';
      mobileMenuButton.setAttribute('aria-expanded', String(!isExpanded));
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
