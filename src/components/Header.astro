---
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';
import Breadcrumbs from './Breadcrumbs.astro';

// Load configuration
const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<header class="bg-white/95 backdrop-blur-md shadow-sm border-b border-gray-100 sticky top-0 z-50 transition-all duration-300" id="site-header">
  <!-- Top bar with contact info (desktop only) -->
  <div class="hidden lg:block text-white text-sm" style="background-color: #1a2d19;" id="top-bar">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center py-2">
      <div class="flex items-center gap-6">
        <a href={`tel:${config.contact.phone}`} class="flex items-center gap-1.5 hover:text-[#c8a96e] transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {config.contact.phone}
        </a>
        <a href={`mailto:${config.contact.email}`} class="flex items-center gap-1.5 hover:text-[#c8a96e] transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          {config.contact.email}
        </a>
        <span class="flex items-center gap-1.5 text-green-300">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {config.contact.businessHours}
        </span>
      </div>
      <div class="flex items-center gap-4">
        {config.social.facebook && (
          <a href={config.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="hover:text-[#c8a96e] transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"/></svg>
          </a>
        )}
        {config.social.instagram && (
          <a href={config.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:text-[#c8a96e] transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        )}
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16 lg:h-18">
      <!-- Logo -->
      <div class="flex items-center">
        <a href={base} class="flex items-center space-x-3 group" aria-label="Home">
          <img
            src={`${base}assets/fc4d1e14-254e-4b76-be45-d60c4aeea6ea.jpg`}
            alt={`${config.site.title} logo`}
            class="h-10 w-10 rounded-full object-cover transition-transform group-hover:scale-105 shadow-sm"
            width="40"
            height="40"
          />
          <div class="flex flex-col">
            <span class="text-lg font-bold text-green-900 leading-tight" style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 700;">{config.site.title}</span>
            <span class="text-[10px] text-green-600 font-medium uppercase tracking-widest hidden sm:block" style="font-variant: small-caps;">Smithers, BC</span>
          </div>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
        <ul class="flex items-center gap-1" role="menubar">
          <li role="none">
            <a
              href={base}
              class={`px-4 py-2 text-sm font-medium rounded-full transition-all ${currentPath === base || currentPath === base.slice(0, -1) ? 'text-green-800 bg-green-50' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-full'}`}
              role="menuitem"
              aria-current={currentPath === base || currentPath === base.slice(0, -1) ? 'page' : undefined}
            >
              Home
            </a>
          </li>
          <li role="none">
            <a
              href={`${base}about/`}
              class={`px-4 py-2 text-sm font-medium rounded-full transition-all ${currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'text-green-800 bg-green-50' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-full'}`}
              role="menuitem"
              aria-current={currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'page' : undefined}
            >
              About
            </a>
          </li>
          {config.features.products && (
            <li role="none">
              <a
                href={`${base}services/`}
                class={`px-4 py-2 text-sm font-medium rounded-full transition-all ${currentPath.includes('/services') ? 'text-green-800 bg-green-50' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-full'}`}
                role="menuitem"
                aria-current={currentPath.includes('/services') ? 'page' : undefined}
              >
                Services
              </a>
            </li>
          )}
          {config.features.blog && (
            <li role="none">
              <a
                href={`${base}blog/`}
                class={`px-4 py-2 text-sm font-medium rounded-full transition-all ${currentPath.includes('/blog') ? 'text-green-800 bg-green-50' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-full'}`}
                role="menuitem"
                aria-current={currentPath.includes('/blog') ? 'page' : undefined}
              >
                Blog
              </a>
            </li>
          )}
          <li role="none">
            <a
              href={`${base}gallery/`}
              class={`px-4 py-2 text-sm font-medium rounded-full transition-all ${currentPath.includes('/gallery') ? 'text-green-800 bg-green-50' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-full'}`}
              role="menuitem"
              aria-current={currentPath.includes('/gallery') ? 'page' : undefined}
            >
              Gallery
            </a>
          </li>
          <li role="none">
            <a
              href={`${base}contact/`}
              class={`px-4 py-2 text-sm font-medium rounded-full transition-all ${currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'text-green-800 bg-green-50' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-full'}`}
              role="menuitem"
              aria-current={currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'page' : undefined}
            >
              Contact
            </a>
          </li>
        </ul>
        <!-- Desktop CTA -->
        <a
          href={`${base}contact/`}
          class="ml-4 inline-flex items-center px-5 py-2.5 rounded-full font-bold text-sm transition-all shadow-sm hover:shadow-md hover:-translate-y-0.5"
          style="background-color: #c8a96e; color: #1a2d19;"
        >
          Free Quote
        </a>
      </nav>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center gap-3">
        <a href={`tel:${config.contact.phone}`} class="text-green-700 p-2" aria-label="Call us">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        </a>
        <button
          type="button"
          class="text-gray-700 hover:text-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 p-2 rounded-full"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle mobile menu"
          id="mobile-menu-button"
        >
          <svg class="h-6 w-6 menu-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="h-6 w-6 close-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div class="md:hidden overflow-hidden transition-all duration-300 max-h-0" id="mobile-menu">
      <div class="px-2 pt-2 pb-4 space-y-1 border-t border-gray-100">
        <a
          href={base}
          class={`block px-4 py-3 text-base font-medium rounded-2xl transition-all ${currentPath === base || currentPath === base.slice(0, -1) ? 'text-green-700 bg-green-50' : 'text-gray-700 hover:text-green-700 hover:bg-gray-50'}`}
          aria-current={currentPath === base || currentPath === base.slice(0, -1) ? 'page' : undefined}
        >
          Home
        </a>
        <a
          href={`${base}about/`}
          class={`block px-4 py-3 text-base font-medium rounded-2xl transition-all ${currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'text-green-700 bg-green-50' : 'text-gray-700 hover:text-green-700 hover:bg-gray-50'}`}
          aria-current={currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'page' : undefined}
        >
          About
        </a>
        {config.features.products && (
          <a
            href={`${base}services/`}
            class={`block px-4 py-3 text-base font-medium rounded-2xl transition-all ${currentPath.includes('/services') ? 'text-green-700 bg-green-50' : 'text-gray-700 hover:text-green-700 hover:bg-gray-50'}`}
            aria-current={currentPath.includes('/services') ? 'page' : undefined}
          >
            Services
          </a>
        )}
        {config.features.blog && (
          <a
            href={`${base}blog/`}
            class={`block px-4 py-3 text-base font-medium rounded-2xl transition-all ${currentPath.includes('/blog') ? 'text-green-700 bg-green-50' : 'text-gray-700 hover:text-green-700 hover:bg-gray-50'}`}
            aria-current={currentPath.includes('/blog') ? 'page' : undefined}
          >
            Blog
          </a>
        )}
        <a
          href={`${base}gallery/`}
          class={`block px-4 py-3 text-base font-medium rounded-2xl transition-all ${currentPath.includes('/gallery') ? 'text-green-700 bg-green-50' : 'text-gray-700 hover:text-green-700 hover:bg-gray-50'}`}
          aria-current={currentPath.includes('/gallery') ? 'page' : undefined}
        >
          Gallery
        </a>
        <a
          href={`${base}contact/`}
          class={`block px-4 py-3 text-base font-medium rounded-2xl transition-all ${currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'text-green-700 bg-green-50' : 'text-gray-700 hover:text-green-700 hover:bg-gray-50'}`}
          aria-current={currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'page' : undefined}
        >
          Contact
        </a>
        <a
          href={`${base}contact/`}
          class="block mx-2 mt-3 text-center px-4 py-3 rounded-full font-bold transition-colors"
          style="background-color: #c8a96e; color: #1a2d19;"
        >
          Get a Free Quote
        </a>
      </div>
    </div>
  </div>

  <!-- Breadcrumbs (for non-home pages) -->
  {currentPath !== base && currentPath !== base.slice(0, -1) && <Breadcrumbs />}
</header>

<script>
  function initHeader() {
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = mobileMenuButton?.querySelector('.menu-icon');
    const closeIcon = mobileMenuButton?.querySelector('.close-icon');

    function closeMenu() {
      if (!mobileMenuButton || !mobileMenu) return;
      mobileMenuButton.setAttribute('aria-expanded', 'false');
      mobileMenu.style.maxHeight = '0';
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    }

    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener('click', () => {
        const isExpanded = mobileMenuButton.getAttribute('aria-expanded') === 'true';
        mobileMenuButton.setAttribute('aria-expanded', String(!isExpanded));

        if (isExpanded) {
          closeMenu();
        } else {
          mobileMenu.style.maxHeight = mobileMenu.scrollHeight + 'px';
          menuIcon?.classList.add('hidden');
          closeIcon?.classList.remove('hidden');
        }
      });

      // Close menu on outside click
      document.addEventListener('click', (e) => {
        if (mobileMenuButton.getAttribute('aria-expanded') === 'true'
            && !mobileMenu.contains(e.target as Node)
            && !mobileMenuButton.contains(e.target as Node)) {
          closeMenu();
        }
      });

      // Close menu on Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileMenuButton.getAttribute('aria-expanded') === 'true') {
          closeMenu();
          mobileMenuButton.focus();
        }
      });

      // Close menu when a nav link is clicked
      mobileMenu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeMenu);
      });
    }

    // Header shrink on scroll
    const header = document.getElementById('site-header');
    const topBar = document.getElementById('top-bar');
    if (header) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 80) {
          header.classList.add('shadow-md');
          topBar?.classList.add('hidden');
        } else {
          header.classList.remove('shadow-md');
          topBar?.classList.remove('hidden');
        }
      }, { passive: true });
    }
  }

  // Re-init on View Transitions navigation
  document.addEventListener('astro:page-load', initHeader);
</script>
