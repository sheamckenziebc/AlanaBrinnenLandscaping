---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

// JSON-LD for contact page
const cContactPt: Record<string, any> = { telephone: config.contact.phone, contactType: "Customer Service", email: config.contact.email, availableLanguage: "English" };
cContactPt["@type"] = "ContactPoint";
const cAddr: Record<string, any> = { streetAddress: config.contact.address, addressLocality: "Smithers", addressRegion: "BC", addressCountry: "CA" };
cAddr["@type"] = "PostalAddress";
const cMainEntity: Record<string, any> = { name: config.site.title, contactPoint: cContactPt, address: cAddr };
cMainEntity["@type"] = "Organization";
const contactObj: Record<string, any> = { mainEntity: cMainEntity };
contactObj["@context"] = "https://schema.org";
contactObj["@type"] = "ContactPage";
const contactJsonLd = JSON.stringify(contactObj);
---

<BaseLayout
  title={`Contact | ${config.site.title}`}
  description="Get in touch with Metta Growing for a free landscaping consultation in Smithers, BC and the Bulkley Valley. Call, email, or fill out our contact form."
>
  <Header slot="header" />

  <!-- PAGE HEADER BAND -->
  <section class="py-20" style="background-color: #1a2d19;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-sm font-semibold uppercase tracking-widest" style="color: #c8a96e;">Let's Talk</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mt-3 mb-4" style="font-family: 'Cormorant Garamond', Georgia, serif;">
        Get in Touch
      </h1>
      <p class="text-green-200 max-w-2xl text-lg">We'd love to hear about your project</p>
      <div class="mt-5 h-1 w-24 rounded" style="background-color: #c8a96e;"></div>
    </div>
  </section>

  <!-- Wave divider: dark→white -->
  <div style="background-color: #1a2d19;" class="-mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 60L80 48C160 36 320 12 480 6C640 0 800 12 960 18C1120 24 1280 24 1360 24L1440 24V60H1360C1280 60 1120 60 960 60C800 60 640 60 480 60C320 60 160 60 80 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- CONTACT FORM & INFO -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12">

        <!-- Form column (3/5) -->
        <div class="lg:col-span-3 animate-on-scroll">
          <div class="rounded-3xl bg-white shadow-sm border border-green-100 p-8 md:p-10">
            <h3 class="text-2xl font-bold text-green-950 mb-2">Tell Us About Your Project</h3>
            <p class="text-gray-500 mb-8 text-sm">We'll get back to you within one business day. Free consultations always available.</p>

            <form
              action="https://formspree.io/f/your-formspree-id"
              method="POST"
              class="space-y-6"
              id="contact-form"
            >
              <!-- Name -->
              <div>
                <label for="name" class="block text-sm font-semibold text-gray-700 mb-2">Full Name *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="Your full name"
                  class="w-full px-4 py-3 border border-green-200 rounded-2xl shadow-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors"
                />
              </div>

              <!-- Phone & Email row -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="phone" class="block text-sm font-semibold text-gray-700 mb-2">Phone Number *</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    autocomplete="tel"
                    placeholder="(250) 555-0100"
                    class="w-full px-4 py-3 border border-green-200 rounded-2xl shadow-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">Email Address *</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    autocomplete="email"
                    placeholder="you@example.com"
                    class="w-full px-4 py-3 border border-green-200 rounded-2xl shadow-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors"
                  />
                </div>
              </div>

              <!-- Service Type -->
              <div>
                <label for="service-type" class="block text-sm font-semibold text-gray-700 mb-2">Service Interested In</label>
                <select
                  id="service-type"
                  name="service-type"
                  class="w-full px-4 py-3 border border-green-200 rounded-2xl shadow-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors"
                >
                  <option value="">Select a service...</option>
                  <option value="landscape-installation">Landscape Installation</option>
                  <option value="lawn-care">Lawn Care & Maintenance</option>
                  <option value="patio-hardscaping">Patio & Hardscaping</option>
                  <option value="plant-starts">Plant Starts & Seedlings</option>
                  <option value="yard-cleanup">Yard Cleanup & Debris Removal</option>
                  <option value="commercial-landscaping">Commercial Landscaping</option>
                  <option value="general-inquiry">General Inquiry</option>
                </select>
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="block text-sm font-semibold text-gray-700 mb-2">Message / Project Description *</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  placeholder="Tell us about your yard, what you'd like done, any timing or budget in mind..."
                  class="w-full px-4 py-3 border border-green-200 rounded-2xl shadow-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors resize-y"
                ></textarea>
              </div>

              <!-- Honeypot spam protection -->
              <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

              <button
                type="submit"
                class="w-full py-4 px-6 rounded-full font-bold text-lg transition-all shadow-sm hover:shadow-md hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-offset-2"
                style="background-color: #c8a96e; color: #1a2d19;"
              >
                Send Message
              </button>
              <p class="text-xs text-gray-400 text-center">We respond within 24 hours. No obligation, no spam.</p>
            </form>

            <!-- Form status -->
            <div id="form-status" class="mt-4 p-4 rounded-2xl hidden" aria-live="polite" role="status">
              <p id="form-message"></p>
            </div>
          </div>
        </div>

        <!-- Contact info column (2/5) -->
        <div class="lg:col-span-2 animate-on-scroll">
          <div class="rounded-3xl p-8 text-white h-full" style="background-color: #1a2d19;">
            <h3 class="text-2xl font-bold mb-2">Contact Metta Growing</h3>
            <p class="text-green-300 mb-8 text-sm">We're a small local business — Alana personally responds to every inquiry.</p>

            <div class="space-y-6">
              <!-- Phone -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: rgba(200,169,110,0.2);">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #c8a96e;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <div class="text-sm font-medium mb-1" style="color: #c8a96e;">Phone</div>
                  <a href="tel:+17053500329" class="text-white font-semibold hover:text-green-200 transition-colors">+1 (705) 350-0329</a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: rgba(200,169,110,0.2);">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #c8a96e;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <div class="text-sm font-medium mb-1" style="color: #c8a96e;">Email</div>
                  <a href="mailto:Mettagrowing@pm.me" class="text-white font-semibold hover:text-green-200 transition-colors break-all">Mettagrowing@pm.me</a>
                </div>
              </div>

              <!-- Hours -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: rgba(200,169,110,0.2);">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #c8a96e;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <div class="text-sm font-medium mb-1" style="color: #c8a96e;">Business Hours</div>
                  <div class="text-white font-semibold">Mon–Sat, 8AM–6PM</div>
                  <div class="text-green-300 text-sm mt-1">Sunday: closed</div>
                </div>
              </div>

              <!-- Location -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: rgba(200,169,110,0.2);">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #c8a96e;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <div class="text-sm font-medium mb-1" style="color: #c8a96e;">Location</div>
                  <div class="text-white font-semibold">Smithers, BC, Canada</div>
                  <div class="text-green-300 text-sm mt-1">Serving the Bulkley Valley</div>
                </div>
              </div>
            </div>

            <!-- Truck photo -->
            <img
              src={`${base}assets/2f42e893-ff78-49bc-b695-a219c3dd058e.jpg`}
              alt="Metta Growing service truck"
              class="rounded-2xl mt-6 w-full h-40 object-cover"
              loading="lazy"
            />

            <!-- Service area pills -->
            <div class="mt-6">
              <div class="text-sm font-medium mb-3" style="color: #c8a96e;">Service Area</div>
              <div class="flex flex-wrap gap-2">
                {["Smithers","Telkwa","Houston","Burns Lake","Hazelton","Terrace"].map(city => (
                  <span class="text-xs px-3 py-1.5 rounded-full font-semibold" style="background-color: #c8a96e; color: #1a2d19;">{city}</span>
                ))}
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- JSON-LD Schema -->
  <script type="application/ld+json" set:html={contactJsonLd} />

  <!-- Form submission handling -->
  <script>
    document.addEventListener('astro:page-load', () => {
      const form = document.getElementById('contact-form') as HTMLFormElement;
      const formStatus = document.getElementById('form-status');
      const formMessage = document.getElementById('form-message');
      const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

      if (!form) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.innerHTML = '<svg class="animate-spin -ml-1 mr-2 h-5 w-5 inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>Sending...';
        }

        const formData = new FormData(form);
        try {
          const response = await fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: { 'Accept': 'application/json' }
          });
          if (response.ok) {
            formStatus!.className = 'mt-4 p-4 rounded-2xl bg-green-50 border border-green-200';
            formMessage!.textContent = "Thank you! We've received your message and will be in touch within one business day.";
            formMessage!.className = 'text-green-800 font-medium';
            form.reset();
          } else {
            throw new Error('Failed');
          }
        } catch {
          formStatus!.className = 'mt-4 p-4 rounded-2xl bg-red-50 border border-red-200';
          formMessage!.textContent = 'Sorry, there was a problem sending your message. Please call us directly or try again.';
          formMessage!.className = 'text-red-800 font-medium';
        }
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send Message';
        }
        formStatus!.classList.remove('hidden');
      });
    });
  </script>

  <Footer slot="footer" />
</BaseLayout>
