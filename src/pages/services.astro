---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const services = [
  {
    id: "landscape-installation",
    title: "Landscape Installation",
    description: "Transform your property with a professionally designed and installed landscape. We handle everything from soil preparation and plant selection to final mulching — all chosen to thrive in northern BC's climate.",
    image: "2f42e893-ff78-49bc-b695-a219c3dd058e.jpg",
    imageAlt: "Metta Growing truck at a garden bed installation site",
    features: [
      "Custom garden bed design & layout",
      "Soil amendment & preparation",
      "Plant selection for Zone 3-4 climate",
      "Mulching & weed barrier installation",
      "Perennials, shrubs & ornamental grasses"
    ],
    price: "[Starting price for landscape installation, e.g. Starting at $XXX]",
    category: "Installation"
  },
  {
    id: "lawn-care",
    title: "Lawn Care & Maintenance",
    description: "A healthy, well-maintained lawn is the foundation of a great yard. Our lawn care programs keep your grass green, dense, and looking its best from spring through fall.",
    image: "da992e23-fc96-4640-89f0-dedd661acfa6.jpg",
    imageAlt: "Zero-turn mower performing lawn aeration service",
    features: [
      "Weekly & bi-weekly mowing",
      "Core aeration for thicker growth",
      "Fertilizing & soil health programs",
      "Edging & trimming included",
      "Seasonal spring & fall upkeep"
    ],
    price: "[Per-visit price for lawn care, e.g. Starting at $XX/visit]",
    category: "Maintenance"
  },
  {
    id: "patio-hardscaping",
    title: "Patio & Hardscaping",
    description: "Create an outdoor living space that lasts decades. We design and install beautiful patios, pathways, and hardscape features using quality materials properly prepared to handle freeze-thaw cycles.",
    image: "7efe9fb6-b906-4cd3-aaa3-6f5d2c5d459f.jpg",
    imageAlt: "Finished cobblestone patio installation by Metta Growing",
    features: [
      "Paver & cobblestone patio installation",
      "Garden pathway design & build",
      "Proper base preparation & drainage",
      "Retaining walls & borders",
      "Long-term freeze-thaw resistant construction"
    ],
    price: "Contact for quote",
    category: "Hardscaping"
  },
  {
    id: "plant-starts",
    title: "Plant Starts & Seedlings",
    description: "Get a jump on our short growing season with strong, healthy starts grown right here in the Bulkley Valley. Custom seed-starting orders welcome — herbs, vegetables, and ornamentals available.",
    image: "104d8802-ae55-4c59-83e9-6a8a4e20c064.jpg",
    imageAlt: "Basil seedlings growing under grow lights",
    features: [
      "Herbs: basil, dill, cilantro, chives & more",
      "Vegetables: tomatoes, peppers, squash & more",
      "Ornamental annuals & perennial starters",
      "Custom seed-starting orders accepted",
      "Hardy varieties selected for northern BC"
    ],
    price: "[$X–$XX/start — your actual price range per plant start]",
    category: "Plants"
  },
  {
    id: "yard-cleanup",
    title: "Yard Cleanup & Debris Removal",
    description: "Start the season fresh or close it down right. Our cleanup crews handle everything from spring debris removal to fall leaf clearing — with full hauling included.",
    image: "c68acc1a-88f9-4a17-ae51-8a6adbb49e34.jpg",
    imageAlt: "Metta Growing truck hauling yard debris and waste",
    features: [
      "Spring & fall cleanup packages",
      "Brush & branch removal",
      "Leaf blowing & bagging",
      "Full debris hauling — we take it away",
      "Garden bed clearing & prep"
    ],
    price: "[Starting price for yard cleanup, e.g. Starting at $XXX]",
    category: "Cleanup"
  },
  {
    id: "commercial-landscaping",
    title: "Commercial Landscaping",
    description: "Make the right first impression with professional commercial landscaping. From downtown Smithers planters to full property maintenance contracts, we keep commercial spaces looking their best all season.",
    image: "03ed4bd0-09cf-484a-b671-3ea80d3e7556.jpg",
    imageAlt: "Commercial planter freshly planted and installed",
    features: [
      "Commercial planter design & installation",
      "Ongoing maintenance contracts available",
      "Seasonal planting & changeovers",
      "Snow-damage repair & spring recovery",
      "Multiple property management"
    ],
    price: "Contact for quote",
    category: "Commercial"
  },
];
---

<BaseLayout
  title={`Services | ${config.site.title}`}
  description="Metta Growing offers landscape installation, lawn care, patio & hardscaping, plant starts, yard cleanup, and commercial landscaping in Smithers and the Bulkley Valley, BC."
>
  <Header slot="header" />

  <!-- PAGE HEADER BAND -->
  <section class="py-16" style="background-color: #1a2d19;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-sm font-semibold uppercase tracking-widest" style="color: #c8a96e;">What We Offer</span>
      <h1 class="text-4xl md:text-5xl font-bold text-white mt-2" style="font-family: 'Playfair Display', serif;">
        Our Services
      </h1>
      <div class="mt-4 h-1 w-24 rounded" style="background-color: #c8a96e;"></div>
      <p class="text-green-200 mt-6 max-w-2xl text-lg">
        Six core services, one team. Everything you need to create and maintain a beautiful outdoor space in northern BC.
      </p>
    </div>
  </section>

  <!-- SERVICES GRID -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-16">
        {services.map((service, i) => (
          <div id={service.id} class={`grid lg:grid-cols-5 gap-10 items-start animate-on-scroll ${i % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
            <!-- Image column -->
            <div class={`lg:col-span-2 ${i % 2 === 1 ? 'lg:order-2' : ''}`}>
              <div class="relative rounded-2xl overflow-hidden shadow-lg">
                <img
                  src={`${base}assets/${service.image}`}
                  alt={service.imageAlt}
                  class="w-full h-72 object-cover"
                  loading="lazy"
                />
                <div class="absolute top-4 left-4">
                  <span class="text-white text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full" style="background-color: rgba(45,90,39,0.9);">{service.category}</span>
                </div>
              </div>
            </div>
            <!-- Content column -->
            <div class={`lg:col-span-3 ${i % 2 === 1 ? 'lg:order-1' : ''}`}>
              <div class="flex items-start justify-between mb-4 flex-wrap gap-3">
                <h2 class="text-3xl font-bold text-green-950" style="font-family: 'Playfair Display', serif;">{service.title}</h2>
                <span class="inline-block px-4 py-2 rounded-full text-sm font-bold" style="background-color: #f5f0e6; color: #2d5a27;">{service.price}</span>
              </div>
              <p class="text-lg text-gray-700 leading-relaxed mb-6">{service.description}</p>
              <ul class="space-y-3 mb-8">
                {service.features.map(feat => (
                  <li class="flex items-center gap-3 text-gray-700">
                    <div class="w-5 h-5 rounded-full bg-green-700 flex items-center justify-center flex-shrink-0">
                      <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                    </div>
                    {feat}
                  </li>
                ))}
              </ul>
              <a
                href={`${base}contact/`}
                class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-semibold transition-all"
                style="background-color: #c8a96e; color: #1a2d19;"
              >
                Get a Quote for This Service
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS SECTION -->
  <section class="py-20" style="background-color: #1a2d19;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-sm font-semibold uppercase tracking-widest" style="color: #c8a96e;">Simple Process</span>
        <h2 class="text-4xl font-bold text-white mt-2" style="font-family: 'Playfair Display', serif;">
          How Every Project Works
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 stagger-children">
        {[
          { step: "01", title: "Free Consultation", desc: "We visit your property, assess the space, and listen to what you want to achieve. No commitment required." },
          { step: "02", title: "Design & Proposal", desc: "We prepare a clear written proposal with scope of work, timeline, and fixed pricing. No surprises." },
          { step: "03", title: "We Do the Work", desc: "Our team arrives on schedule, works professionally, and keeps the site tidy throughout the project." },
          { step: "04", title: "Walkthrough & Follow-Up", desc: "We do a final walkthrough together to make sure everything meets your expectations. We're not done until you're happy." },
        ].map(step => (
          <div class="animate-on-scroll text-center p-6">
            <div class="w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-5 border-2" style="background-color: rgba(200,169,110,0.15); border-color: #c8a96e;">
              <span class="text-lg font-bold" style="color: #c8a96e; font-family: 'Playfair Display', serif;">{step.step}</span>
            </div>
            <h3 class="text-lg font-bold text-white mb-3" style="font-family: 'Playfair Display', serif;">{step.title}</h3>
            <p class="text-green-200 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background-color: #f5f0e6;" class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <h2 class="text-3xl font-bold text-green-950 mb-4" style="font-family: 'Playfair Display', serif;">
        Not Sure Where to Start?
      </h2>
      <p class="text-gray-700 text-lg mb-8">
        Book a free consultation and we'll help you figure out exactly what your yard needs and what it will cost.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${base}contact/`}
          class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-bold text-lg transition-all shadow-sm"
          style="background-color: #2d5a27; color: white;"
        >
          Book Free Consultation
        </a>
        <a
          href={`tel:+17053500329`}
          class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold text-lg border-2 transition-all"
          style="border-color: #2d5a27; color: #2d5a27;"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call Now
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
