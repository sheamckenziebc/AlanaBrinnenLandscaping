---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const services = [
  {
    id: "landscape-installation",
    title: "Landscape Installation",
    category: "Garden Design",
    image: "03ed4bd0-09cf-484a-b671-3ea80d3e7556.jpg",
    imageAlt: "Commercial planter freshly planted and installed by Metta Growing",
    description: "PLACEHOLDER_LANDSCAPE_INSTALLATION",
    features: ["PLACEHOLDER_FEATURES"],
    price: "PLACEHOLDER_LANDSCAPE_PRICE"
  },
  {
    id: "lawn-care",
    title: "Lawn Care & Maintenance",
    category: "Lawn Care",
    image: "da992e23-fc96-4640-89f0-dedd661acfa6.jpg",
    imageAlt: "Zero-turn mower performing lawn aeration service",
    description: "PLACEHOLDER_LAWN_CARE",
    features: ["PLACEHOLDER_FEATURES"],
    price: "PLACEHOLDER_LAWN_PRICE"
  },
  {
    id: "patio-hardscaping",
    title: "Patio & Hardscaping",
    category: "Hardscaping",
    image: "7efe9fb6-b907-4be8-8017-d3e5b741a6b4.jpg",
    imageAlt: "Finished cobblestone patio installation by Metta Growing",
    description: "PLACEHOLDER_PATIO",
    features: ["PLACEHOLDER_FEATURES"],
    price: "PLACEHOLDER_PATIO_PRICE"
  },
  {
    id: "plant-starts",
    title: "Plant Starts & Seedlings",
    category: "Growing",
    image: "104d8802-ae55-4c59-83e9-6a8a4e20c064.jpg",
    imageAlt: "Basil seedlings growing under grow lights in Smithers",
    description: "PLACEHOLDER_PLANT_STARTS",
    features: ["PLACEHOLDER_FEATURES"],
    price: "PLACEHOLDER_PLANT_PRICE"
  },
  {
    id: "yard-cleanup",
    title: "Yard Cleanup & Debris Removal",
    category: "Cleanup",
    image: "c68acc1a-88f9-4a17-ae51-8a6adbb49e34.jpg",
    imageAlt: "Metta Growing truck hauling yard debris and waste",
    description: "PLACEHOLDER_YARD_CLEANUP",
    features: ["PLACEHOLDER_FEATURES"],
    price: "PLACEHOLDER_CLEANUP_PRICE"
  },
  {
    id: "commercial-landscaping",
    title: "Commercial Landscaping",
    category: "Commercial",
    image: "d7761b7c-b907-4be8-8017-d3e5b741a6b4.jpg",
    imageAlt: "Commercial planter with mixed shrubs at Smithers business",
    description: "PLACEHOLDER_COMMERCIAL",
    features: ["PLACEHOLDER_FEATURES"],
    price: "PLACEHOLDER_COMMERCIAL_PRICE"
  },
];
---

<BaseLayout
  title={`Services | ${config.site.title}`}
  description="Metta Growing offers landscape installation, lawn care, patio & hardscaping, plant starts, yard cleanup, and commercial landscaping in Smithers and the Bulkley Valley, BC."
>
  <Header slot="header" />

  <!-- PAGE HEADER BAND -->
  <section class="py-20" style="background-color: #1a2d19;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-sm font-semibold uppercase tracking-widest" style="color: #c8a96e;">What We Offer</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mt-3 mb-4" style="font-family: 'Cormorant Garamond', Georgia, serif;">
        Our Services
      </h1>
      <p class="text-green-200 max-w-2xl text-lg">Professional landscaping for homes and businesses in the Bulkley Valley</p>
      <div class="mt-5 h-1 w-24 rounded" style="background-color: #c8a96e;"></div>
    </div>
  </section>

  <!-- Wave divider: dark→white -->
  <div style="background-color: #1a2d19;" class="-mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 60L80 48C160 36 320 12 480 6C640 0 800 12 960 18C1120 24 1280 24 1360 24L1440 24V60H1360C1280 60 1120 60 960 60C800 60 640 60 480 60C320 60 160 60 80 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- SERVICES — full alternating sections -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-24">
        {services.map((service, i) => (
          <div id={service.id} class="grid lg:grid-cols-5 gap-12 items-center animate-on-scroll">
            <!-- Image column -->
            <div class={`lg:col-span-2 ${i % 2 === 1 ? 'lg:order-2' : ''}`}>
              <div class="relative rounded-3xl overflow-hidden shadow-md">
                <img
                  src={`${base}assets/${service.image}`}
                  alt={service.imageAlt}
                  class="w-full h-72 object-cover"
                  loading="lazy"
                />
                <div class="absolute top-4 left-4">
                  <span class="text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full" style="background-color: #c8a96e; color: #1a2d19;">{service.category}</span>
                </div>
              </div>
            </div>
            <!-- Content column -->
            <div class={`lg:col-span-3 ${i % 2 === 1 ? 'lg:order-1' : ''}`}>
              <div class="flex items-start justify-between mb-4 flex-wrap gap-3">
                <h2 class="text-3xl md:text-4xl font-bold text-green-950" style="font-family: 'Cormorant Garamond', Georgia, serif;">{service.title}</h2>
                <span class="inline-block px-4 py-2 rounded-full text-sm font-bold border" style="background-color: #f5f0e6; color: #2d5a27; border-color: #c8a96e30;">{service.price}</span>
              </div>
              <p class="text-lg text-gray-700 leading-relaxed mb-6">{service.description}</p>
              <ul class="space-y-3 mb-8">
                {service.features.map(feat => (
                  <li class="flex items-center gap-3 text-gray-700">
                    <div class="w-5 h-5 rounded-full bg-green-700 flex items-center justify-center flex-shrink-0">
                      <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                    </div>
                    {feat}
                  </li>
                ))}
              </ul>
              <a
                href={`${base}contact/`}
                class="inline-flex items-center justify-center px-8 py-4 rounded-full font-semibold text-base transition-all shadow-sm hover:shadow-md hover:-translate-y-0.5"
                style="background-color: #c8a96e; color: #1a2d19;"
              >
                Get a Quote for This Service
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Wave divider: white→dark -->
  <div class="bg-white -mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 0L80 12C160 24 320 48 480 54C640 60 800 48 960 42C1120 36 1280 36 1360 36L1440 36V0H1360C1280 0 1120 0 960 0C800 0 640 0 480 0C320 0 160 0 80 0H0Z" fill="#1a2d19"/>
    </svg>
  </div>

  <!-- PROCESS SECTION -->
  <section class="py-20" style="background-color: #1a2d19;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-sm font-semibold uppercase tracking-widest" style="color: #c8a96e;">Simple Process</span>
        <h2 class="text-4xl md:text-5xl font-bold text-white mt-2" style="font-family: 'Cormorant Garamond', Georgia, serif;">
          Our Process
        </h2>
        <p class="text-green-300 mt-4 max-w-xl mx-auto">Every project follows the same simple, transparent process.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 stagger-children">
        {[
          { step: "01", title: "Consultation", desc: "We visit your property, assess the space, and listen to what you want to achieve. No commitment required." },
          { step: "02", title: "Proposal", desc: "We prepare a clear written proposal with scope of work, timeline, and fixed pricing. No surprises." },
          { step: "03", title: "Installation", desc: "Our team arrives on schedule, works professionally, and keeps the site tidy throughout the project." },
          { step: "04", title: "Walkthrough", desc: "We do a final walkthrough together to make sure everything meets your expectations. We're not done until you're happy." },
        ].map(step => (
          <div class="animate-on-scroll text-center p-6">
            <div class="w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-5 border-2" style="background-color: rgba(200,169,110,0.15); border-color: #c8a96e;">
              <span class="text-lg font-bold" style="color: #c8a96e; font-family: 'Cormorant Garamond', Georgia, serif;">{step.step}</span>
            </div>
            <h3 class="text-lg font-bold text-white mb-3">{step.title}</h3>
            <p class="text-green-300 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Wave divider: dark→white -->
  <div style="background-color: #1a2d19;" class="-mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 60L80 48C160 36 320 12 480 6C640 0 800 12 960 18C1120 24 1280 24 1360 24L1440 24V60H1360C1280 60 1120 60 960 60C800 60 640 60 480 60C320 60 160 60 80 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- FINAL CTA -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <h2 class="text-4xl font-bold text-green-950 mb-4" style="font-family: 'Cormorant Garamond', Georgia, serif;">
        Ready to Get Started?
      </h2>
      <p class="text-gray-700 text-lg mb-8">
        Book a free consultation and we'll help you figure out exactly what your yard needs and what it will cost.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${base}contact/`}
          class="inline-flex items-center justify-center px-8 py-4 rounded-full font-bold text-lg transition-all shadow-sm hover:shadow-md hover:-translate-y-0.5"
          style="background-color: #c8a96e; color: #1a2d19;"
        >
          Book Free Consultation
        </a>
        <a
          href={`tel:+17053500329`}
          class="inline-flex items-center justify-center px-8 py-4 rounded-full font-semibold text-lg border-2 transition-all"
          style="border-color: #2d5a27; color: #2d5a27;"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call Now
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
