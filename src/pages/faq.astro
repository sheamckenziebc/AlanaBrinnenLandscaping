---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const faqs = [
  {
    question: "What areas do you serve?",
    answer: "Metta Growing is based in Smithers, BC and serves communities throughout the Bulkley Valley including Telkwa, Houston, Burns Lake, Hazelton, and Terrace. Not sure if you're in our area? Just reach out — we're flexible."
  },
  {
    question: "Do you offer free consultations?",
    answer: "Yes! We always start with a free consultation at your property. We'll walk through your space, discuss your vision, and talk through options. There's no obligation and no pressure."
  },
  {
    question: "When is the best time to start a landscaping project in Smithers?",
    answer: "Most outdoor installation work happens between May and September when the ground is workable. Spring is our busiest booking season, so we recommend reaching out in March or April for summer projects. Plant starts are available from late April through July."
  },
  {
    question: "What plants grow well in Smithers/Bulkley Valley?",
    answer: "We're in a Zone 3-4 climate, so we focus on cold-hardy perennials, native species, and tough ornamentals like Siberian iris, hardy roses, ornamental grasses, and sedums. We'll always recommend species that are proven performers in our local conditions."
  },
  {
    question: "How do your plant starts work — can I order custom varieties?",
    answer: "Absolutely. We start seeds indoors in late winter under grow lights and harden them off before they're available. We typically carry basil, cilantro, dill, tomatoes, peppers, and a rotating selection of ornamentals. Custom orders for specific varieties are welcome — just ask early!"
  },
  {
    question: "Do you take on commercial properties?",
    answer: "Yes. We work with businesses in Smithers and surrounding communities for planter installation, parking lot landscaping, and ongoing maintenance contracts. Commercial clients get consistent, reliable service on a scheduled basis."
  },
  {
    question: "How do I prepare for a patio installation?",
    answer: "We handle all the prep work — excavation, base compaction, drainage planning. You don't need to do anything special beforehand. We'll walk through the area together during the consultation and flag anything relevant."
  },
  {
    question: "Do you offer ongoing maintenance contracts?",
    answer: "Yes, seasonal and annual maintenance contracts are available for both residential and commercial clients. These can include regular mowing, planter upkeep, spring/fall cleanups, and more. Contact us to discuss what works for your property."
  }
];

// FAQPage JSON-LD schema
const faqItems = faqs.map(f => {
  const item: Record<string, any> = { name: f.question, acceptedAnswer: { text: f.answer } };
  item["@type"] = "Question";
  item.acceptedAnswer["@type"] = "Answer";
  return item;
});
const faqObj: Record<string, any> = { mainEntity: faqItems };
faqObj["@context"] = "https://schema.org";
faqObj["@type"] = "FAQPage";
const faqJsonLd = JSON.stringify(faqObj);
---

<BaseLayout
  title={`FAQ | ${config.site.title}`}
  description="Frequently asked questions about Metta Growing's landscaping services in Smithers, BC — including service area, pricing, plant starts, and more."
>
  <Header slot="header" />

  <!-- PAGE HEADER BAND -->
  <section class="py-20" style="background-color: #1a2d19;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-sm font-semibold uppercase tracking-widest" style="color: #c8a96e;">Common Questions</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mt-3 mb-4" style="font-family: 'Cormorant Garamond', Georgia, serif;">
        Frequently Asked Questions
      </h1>
      <p class="text-green-200 max-w-2xl text-lg">Honest answers to the questions we hear most from Bulkley Valley homeowners and property managers.</p>
      <div class="mt-5 h-1 w-24 rounded" style="background-color: #c8a96e;"></div>
    </div>
  </section>

  <!-- Wave divider: dark→white -->
  <div style="background-color: #1a2d19;" class="-mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 60L80 48C160 36 320 12 480 6C640 0 800 12 960 18C1120 24 1280 24 1360 24L1440 24V60H1360C1280 60 1120 60 960 60C800 60 640 60 480 60C320 60 160 60 80 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- FAQ ACCORDION -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-4">
        {faqs.map((faq, index) => (
          <details open={index === 0} class="group border border-green-100 rounded-3xl overflow-hidden mb-4">
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none hover:bg-green-50 transition-colors [&::-webkit-details-marker]:hidden">
              <span class="font-semibold text-green-900 pr-4">{faq.question}</span>
              <svg class="w-5 h-5 text-green-600 flex-shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-green-100 pt-4">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Still have questions CTA -->
  <section style="background-color: #f5f0e6;" class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <h3 class="text-3xl font-bold text-green-950 mb-4" style="font-family: 'Cormorant Garamond', Georgia, serif;">Still Have Questions?</h3>
      <p class="text-gray-700 mb-8">
        We're happy to talk through your project and answer any questions. Reach out by phone or send us a message.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${base}contact/`}
          class="inline-flex items-center justify-center px-8 py-4 rounded-full font-semibold text-base transition-all shadow-sm hover:shadow-md hover:-translate-y-0.5"
          style="background-color: #c8a96e; color: #1a2d19;"
        >
          Contact Us
        </a>
        <a
          href="tel:+17053500329"
          class="inline-flex items-center justify-center px-8 py-4 rounded-full font-semibold text-base border-2 transition-all"
          style="border-color: #2d5a27; color: #2d5a27;"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call +1 (705) 350-0329
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={faqJsonLd} />
  <Footer slot="footer" />
</BaseLayout>
