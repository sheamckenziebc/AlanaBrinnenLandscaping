---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

// JSON-LD for about page
const aboutLogoUrl = new URL(config.branding.logo, Astro.site).href;
const contactPt: Record<string, any> = { telephone: config.contact.phone, contactType: "Customer Service", email: config.contact.email };
contactPt["@type"] = "ContactPoint";
const addr: Record<string, any> = { streetAddress: config.contact.address, addressLocality: "Smithers", addressRegion: "BC", addressCountry: "CA" };
addr["@type"] = "PostalAddress";
const mainEntity: Record<string, any> = { name: config.site.title, description: config.site.description, url: config.site.url, logo: aboutLogoUrl, contactPoint: contactPt, address: addr };
mainEntity["@type"] = "Organization";
const aboutObj: Record<string, any> = { mainEntity };
aboutObj["@context"] = "https://schema.org";
aboutObj["@type"] = "AboutPage";
const aboutJsonLd = JSON.stringify(aboutObj);
---

<BaseLayout
  title={`About Metta Growing | ${config.site.title}`}
  description="Learn about Metta Growing — Alana Brinnen's passionate landscaping business rooted in Smithers, BC. Discover our story, values, and commitment to the Bulkley Valley."
>
  <Header slot="header" />

  <!-- PAGE HEADER BAND -->
  <section class="py-20" style="background-color: #1a2d19;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-sm font-semibold uppercase tracking-widest" style="color: #c8a96e;">Get to Know Us</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mt-3 mb-4" style="font-family: 'Cormorant Garamond', Georgia, serif;">
        About Metta Growing
      </h1>
      <p class="text-green-200 max-w-2xl text-lg">A small, passionate landscaping company rooted in Smithers, BC</p>
      <div class="mt-5 h-1 w-24 rounded" style="background-color: #c8a96e;"></div>
    </div>
  </section>

  <!-- Wave divider: dark→white -->
  <div style="background-color: #1a2d19;" class="-mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 60L80 48C160 36 320 12 480 6C640 0 800 12 960 18C1120 24 1280 24 1360 24L1440 24V60H1360C1280 60 1120 60 960 60C800 60 640 60 480 60C320 60 160 60 80 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- STORY SECTION -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12 items-start">
        <!-- Story text left -->
        <div class="lg:col-span-3 animate-on-scroll">
          <span class="text-sm font-semibold uppercase tracking-widest text-green-700">Our Story</span>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-green-950 mt-2 mb-6" style="font-family: 'Cormorant Garamond', Georgia, serif;">
            Grown from a Passion for the Land
          </h2>
          <p class="text-lg text-gray-700 leading-relaxed mb-5">
            Metta Growing is Alana Brinnen's hands-on landscaping practice in Smithers, BC. Rooted in a deep love for the land and a genuine connection to the Bulkley Valley, Alana founded Metta Growing to bring real, lasting beauty to the outdoor spaces of her community.
          </p>
          <p class="text-lg text-gray-700 leading-relaxed mb-5">
            Every project reflects the same personal commitment: listen carefully, work with care, and never leave until the space is something the client is genuinely proud of. Whether it's a new garden bed, a cobblestone patio, or a flat of freshly grown herb starts, the same hands-on attention guides every job.
          </p>
          <p class="text-lg text-gray-700 leading-relaxed mb-8">
            The name "Metta" comes from a word meaning loving-kindness — a quality that shows in how Alana approaches both her clients and the natural world. She believes that caring for a landscape is an act of care for the community itself.
          </p>

          <!-- Quote block -->
          <blockquote class="border-l-4 pl-6 py-2 my-8 italic text-xl text-green-800" style="border-color: #c8a96e; font-family: 'Cormorant Garamond', Georgia, serif;">
            "Every yard has potential. My job is to help you see it."
            <footer class="mt-2 text-sm font-semibold not-italic text-green-700" style="font-family: 'DM Sans', sans-serif;">— Alana Brinnen, Founder</footer>
          </blockquote>

          <!-- Stats row -->
          <div class="grid grid-cols-3 gap-4 mt-8">
            {[
              { value: "5+", label: "Years in Business" },
              { value: "100+", label: "Projects Completed" },
              { value: "6", label: "Communities Served" },
            ].map(stat => (
              <div class="text-center p-5 rounded-3xl border border-green-100" style="background-color: #f5f0e6;">
                <div class="text-3xl font-bold text-green-700" style="font-family: 'Cormorant Garamond', Georgia, serif;">{stat.value}</div>
                <div class="text-sm text-gray-600 mt-1">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Photo right -->
        <div class="lg:col-span-2 animate-on-scroll">
          <div class="sticky top-24">
            <img
              src={`${base}assets/e3bb3112-bc50-4f9e-bf8d-b79d369c40e3.jpg`}
              alt="Alana Brinnen, owner of Metta Growing, with wheelbarrow in garden"
              class="rounded-3xl shadow-xl w-full object-cover"
              style="height: 520px;"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave divider: white→cream -->
  <div class="bg-white -mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 60L80 48C160 36 320 12 480 6C640 0 800 12 960 18C1120 24 1280 24 1360 24L1440 24V60H1360C1280 60 1120 60 960 60C800 60 640 60 480 60C320 60 160 60 80 60H0Z" fill="#f5f0e6"/>
    </svg>
  </div>

  <!-- VALUES SECTION -->
  <section style="background-color: #f5f0e6;" class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-sm font-semibold uppercase tracking-widest text-green-700">What We Stand For</span>
        <h2 class="text-4xl md:text-5xl font-bold text-green-950 mt-2" style="font-family: 'Cormorant Garamond', Georgia, serif;">
          What We Stand For
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
        {[
          {
            icon: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z",
            title: "Rooted Locally",
            desc: "Every decision Metta Growing makes is filtered through one question: what's right for this community and this landscape? We're not a franchise — we're your neighbour, and this valley is our home."
          },
          {
            icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
            title: "Grown with Care",
            desc: "Whether it's a seeding tray or a 500 sq ft patio, every project gets Alana's full attention and genuine pride in the result. We work sustainably, using plants suited to local conditions."
          },
          {
            icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
            title: "Built to Last",
            desc: "Quality materials, proper prep work, and honest advice — because a landscape should look better every year, not worse. We do it right the first time so you don't have to call us back."
          },
        ].map((val) => (
          <div class="animate-on-scroll card-hover bg-white rounded-3xl shadow-sm border border-green-100 p-8">
            <div class="w-12 h-12 bg-green-700 rounded-xl flex items-center justify-center mb-6 card-icon">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={val.icon}/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-green-900 mb-3">{val.title}</h3>
            <p class="text-gray-600 leading-relaxed">{val.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WORK PHOTO GRID -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-sm font-semibold uppercase tracking-widest text-green-700">Our Work</span>
        <h2 class="text-4xl font-bold text-green-950 mt-2" style="font-family: 'Cormorant Garamond', Georgia, serif;">
          A Sample of Our Work
        </h2>
        <p class="text-xl text-gray-600 mt-4 max-w-2xl mx-auto">Real projects from across the Bulkley Valley — every one a collaboration with a happy client.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 animate-on-scroll">
        {[
          { src: "7efe9fb6-b907-4be8-8017-d3e5b741a6b4.jpg", alt: "Cobblestone patio installation", caption: "Patio & Hardscaping" },
          { src: "03ed4bd0-09cf-484a-b671-3ea80d3e7556.jpg", alt: "Commercial planter freshly planted", caption: "Commercial Planter" },
          { src: "da992e23-fc96-4640-89f0-dedd661acfa6.jpg", alt: "Lawn aeration service", caption: "Lawn Care" },
          { src: "104d8802-ae55-4c59-83e9-6a8a4e20c064.jpg", alt: "Custom herb starts under grow lights", caption: "Plant Starts" },
          { src: "e3bb3112-bc50-4f9e-bf8d-b79d369c40e3.jpg", alt: "Alana at work in the garden", caption: "Garden Maintenance" },
          { src: "d7761b7c-b907-4be8-8017-d3e5b741a6b4.jpg", alt: "Commercial planter mixed shrubs", caption: "Landscape Installation" },
        ].map((img) => (
          <div class="group relative overflow-hidden rounded-2xl shadow-sm">
            <img
              src={`${base}assets/${img.src}`}
              alt={img.alt}
              class="w-full h-56 object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-green-950/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
              <span class="text-white text-sm font-semibold">{img.caption}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-8 animate-on-scroll">
        <a href={`${base}gallery/`} class="inline-flex items-center text-green-700 font-semibold hover:text-green-900 transition-colors text-lg">
          View the Full Gallery
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="py-20" style="background-color: #1a2d19;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="text-sm font-semibold uppercase tracking-widest" style="color: #c8a96e;">Where We Work</span>
        <h2 class="text-4xl md:text-5xl font-bold text-white mt-2" style="font-family: 'Cormorant Garamond', Georgia, serif;">
          Proudly Serving
        </h2>
        <p class="text-green-300 mt-4 max-w-xl mx-auto text-lg">Based in Smithers, BC — reaching across the Bulkley Valley</p>
      </div>

      <div class="flex flex-wrap justify-center gap-3 mb-10 animate-on-scroll">
        {["Smithers", "Telkwa", "Houston", "Burns Lake", "Hazelton", "Terrace"].map((city) => (
          <span class="px-5 py-2.5 rounded-full font-semibold text-sm" style="background-color: #c8a96e; color: #1a2d19;">{city}</span>
        ))}
      </div>

      <div class="max-w-xl mx-auto text-center animate-on-scroll">
        <p class="text-green-300 text-base">Not on the list? Get in touch — we may still be able to help.</p>
        <a href={`${base}contact/`} class="inline-flex items-center justify-center mt-4 px-6 py-3 rounded-full font-semibold text-sm border border-white/30 text-white hover:bg-white/10 transition-all">
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <h2 class="text-4xl font-bold text-green-950 mb-4" style="font-family: 'Cormorant Garamond', Georgia, serif;">
        Let's Start Your Project
      </h2>
      <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
        Book a free consultation and let Alana visit your property to talk through what's possible.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${base}contact/`}
          class="inline-flex items-center justify-center px-8 py-4 rounded-full font-bold text-lg transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
          style="background-color: #c8a96e; color: #1a2d19;"
        >
          Get a Free Quote
        </a>
        <a
          href={`tel:+17053500329`}
          class="inline-flex items-center justify-center px-8 py-4 rounded-full font-semibold text-lg border-2 transition-all"
          style="border-color: #2d5a27; color: #2d5a27;"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call Alana
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={aboutJsonLd} />
  <Footer slot="footer" />
</BaseLayout>
