---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

// JSON-LD for about page
const aboutLogoUrl = new URL(config.branding.logo, Astro.site).href;
const contactPt: Record<string, any> = { telephone: config.contact.phone, contactType: "Customer Service", email: config.contact.email };
contactPt["@type"] = "ContactPoint";
const addr: Record<string, any> = { streetAddress: config.contact.address, addressLocality: "Smithers", addressRegion: "BC", addressCountry: "CA" };
addr["@type"] = "PostalAddress";
const mainEntity: Record<string, any> = { name: config.site.title, description: config.site.description, url: config.site.url, logo: aboutLogoUrl, contactPoint: contactPt, address: addr };
mainEntity["@type"] = "Organization";
const aboutObj: Record<string, any> = { mainEntity };
aboutObj["@context"] = "https://schema.org";
aboutObj["@type"] = "AboutPage";
const aboutJsonLd = JSON.stringify(aboutObj);
---

<BaseLayout
  title={`About Metta Growing | ${config.site.title}`}
  description="Learn about Metta Growing — Alana Brinnen's passionate landscaping business rooted in Smithers, BC. Discover our story, values, and commitment to the Bulkley Valley."
>
  <Header slot="header" />

  <!-- PAGE HEADER BAND -->
  <section class="py-16" style="background-color: #1a2d19;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-sm font-semibold uppercase tracking-widest" style="color: #c8a96e;">Our Story</span>
      <h1 class="text-4xl md:text-5xl font-bold text-white mt-2" style="font-family: 'Playfair Display', serif;">
        About Metta Growing
      </h1>
      <div class="mt-4 h-1 w-24 rounded" style="background-color: #c8a96e;"></div>
    </div>
  </section>

  <!-- STORY SECTION: asymmetric layout -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12 items-start">
        <!-- Story text left -->
        <div class="lg:col-span-3 animate-on-scroll">
          <span class="text-sm font-semibold uppercase tracking-widest text-green-700">Rooted in the Bulkley Valley</span>
          <h2 class="text-3xl md:text-4xl font-bold text-green-950 mt-2 mb-6" style="font-family: 'Playfair Display', serif;">
            A Passion for Growing, A Love for This Land
          </h2>
          <p class="text-lg text-gray-700 leading-relaxed mb-5">
            [Paragraph 1 — Origin story: How and when did Metta Growing start? What drew Alana to landscaping? E.g. when she founded the business, what inspired her, her background or connection to the Bulkley Valley. Tell it in your own words.]
          </p>
          <p class="text-lg text-gray-700 leading-relaxed mb-5">
            [Paragraph 2 — Your approach: How do you work? What do you care about most? E.g. your relationship to the land, to clients, to sustainable practices. What makes Metta Growing different from a generic landscaping company?]
          </p>
          <p class="text-lg text-gray-700 leading-relaxed mb-5">
            [Paragraph 3 — The name "Metta Growing": What does it mean to you personally? Why did you choose this name? This is a chance to share your values and personality in your own voice.]
          </p>
          <p class="text-lg text-gray-700 leading-relaxed mb-8">
            [Paragraph 4 — What you offer and who you serve: A closing sentence or two about the range of work you do and the kinds of clients and projects you love most.]
          </p>
          <!-- Stats row -->
          <div class="grid grid-cols-3 gap-4 mt-8">
            {[
              { value: "[X+]", label: "Years in Business" },
              { value: "[X+]", label: "Projects Completed" },
              { value: "[X]", label: "Communities Served" },
            ].map(stat => (
              <div class="text-center p-4 rounded-xl" style="background-color: #f5f0e6;">
                <div class="text-3xl font-bold text-green-700" style="font-family: 'Playfair Display', serif;">{stat.value}</div>
                <div class="text-sm text-gray-600 mt-1">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Photo right -->
        <div class="lg:col-span-2 animate-on-scroll">
          <div class="sticky top-24">
            <img
              src={`${base}assets/e3bb3112-bc50-4f9e-bf8d-b79d369c40e3.jpg`}
              alt="Alana Brinnen, owner of Metta Growing, with wheelbarrow in garden"
              class="rounded-2xl shadow-xl w-full object-cover"
              style="height: 500px;"
              loading="lazy"
            />
            <div class="mt-4 p-5 rounded-xl border" style="background-color: #f5f0e6; border-color: #c8a96e30;">
              <p class="text-green-800 italic text-base leading-relaxed">
                "[A real quote from Alana — something she actually says about why she does this work, what she loves about it, or what Metta Growing means to her. In her own words.]"
              </p>
              <p class="text-green-700 font-semibold mt-3">— Alana Brinnen, Founder</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES SECTION -->
  <section style="background-color: #f5f0e6;" class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-sm font-semibold uppercase tracking-widest text-green-700">What We Stand For</span>
        <h2 class="text-4xl font-bold text-green-950 mt-2" style="font-family: 'Playfair Display', serif;">
          Our Core Values
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
        {[
          {
            icon: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z",
            title: "Rooted Locally",
            desc: "We live and work in the Bulkley Valley. Every decision we make is informed by a deep understanding of this climate, this soil, and this community. We're not a franchise — we're your neighbour."
          },
          {
            icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
            title: "Grown with Care",
            desc: "We practice sustainable landscaping — using plants suited to the local climate, minimizing waste, and working in harmony with the natural environment. We think about the long-term health of your yard."
          },
          {
            icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
            title: "Built to Last",
            desc: "Whether it's a patio or a garden bed, we do it right the first time. Proper base preparation, quality materials, and attention to detail mean your investment stands up season after season."
          },
        ].map((val) => (
          <div class="animate-on-scroll card-hover bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
            <div class="w-12 h-12 bg-green-700 rounded-xl flex items-center justify-center mb-6 card-icon">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={val.icon}/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-green-900 mb-3" style="font-family: 'Playfair Display', serif;">{val.title}</h3>
            <p class="text-gray-600 leading-relaxed">{val.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT WE GROW / WORK PHOTO GRID -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-sm font-semibold uppercase tracking-widest text-green-700">Our Work</span>
        <h2 class="text-4xl font-bold text-green-950 mt-2" style="font-family: 'Playfair Display', serif;">
          What We Grow & Build
        </h2>
        <p class="text-xl text-gray-600 mt-4 max-w-2xl mx-auto">A sample of the landscapes, patios, and plant starts we've created across the Bulkley Valley.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 animate-on-scroll">
        {[
          { src: "7efe9fb6-b906-4cd3-aaa3-6f5d2c5d459f.jpg", alt: "Finished cobblestone patio" },
          { src: "03ed4bd0-09cf-484a-b671-3ea80d3e7556.jpg", alt: "Commercial planter freshly planted" },
          { src: "adb57937-6079-4847-95a3-8bdd9d6e5fad.jpg", alt: "Lush basil plants" },
          { src: "c68acc1a-88f9-4a17-ae51-8a6adbb49e34.jpg", alt: "Yard cleanup and debris removal" },
          { src: "11ce0f1a-bea6-4ca7-8878-f3fb8fef6bd2.jpg", alt: "Established commercial planter" },
          { src: "e155339b-b8c4-4087-aec4-54e41447735a.jpg", alt: "Patio base preparation" },
        ].map((img) => (
          <div class="overflow-hidden rounded-xl shadow-sm group">
            <img
              src={`${base}assets/${img.src}`}
              alt={img.alt}
              class="w-full h-48 md:h-56 object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
        ))}
      </div>
      <div class="text-center mt-8 animate-on-scroll">
        <a href={`${base}gallery/`} class="inline-flex items-center text-green-700 font-semibold hover:text-green-900 transition-colors text-lg">
          View the Full Gallery
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="py-20" style="background-color: #f5f0e6;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="text-sm font-semibold uppercase tracking-widest text-green-700">Where We Work</span>
        <h2 class="text-4xl font-bold text-green-950 mt-2" style="font-family: 'Playfair Display', serif;">
          Serving the Bulkley Valley & Beyond
        </h2>
        <p class="text-gray-600 mt-4 max-w-2xl mx-auto text-lg">From Smithers to Terrace, we bring quality landscaping to communities across northwestern BC.</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-4 animate-on-scroll mb-10">
        {["Smithers", "Telkwa", "Houston", "Burns Lake", "Hazelton", "Terrace"].map((city) => (
          <div class="flex flex-col items-center gap-2 bg-white rounded-xl px-4 py-5 border border-gray-200 shadow-sm text-center">
            <svg class="w-6 h-6 text-green-700 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="text-sm font-semibold text-gray-800">{city}</span>
          </div>
        ))}
      </div>

      <div class="max-w-2xl mx-auto bg-white rounded-2xl p-6 border border-gray-200 shadow-sm text-center animate-on-scroll">
        <svg class="w-8 h-8 text-green-700 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <p class="text-gray-700 font-medium">Not sure if we serve your area? <a href={`${base}contact/`} class="text-green-700 font-semibold hover:underline">Get in touch</a> — we're happy to discuss your project wherever you are in the region.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20" style="background-color: #1a2d19;">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <h2 class="text-4xl font-bold text-white mb-4" style="font-family: 'Playfair Display', serif;">
        Ready to Work Together?
      </h2>
      <p class="text-xl text-green-200 mb-8 max-w-2xl mx-auto">
        Book a free consultation and let Alana visit your property to talk through what's possible.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${base}contact/`}
          class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-bold text-lg transition-all shadow-lg"
          style="background-color: #c8a96e; color: #1a2d19;"
        >
          Book a Consultation
        </a>
        <a
          href={`${base}services/`}
          class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold text-lg border-2 border-white/40 text-white hover:bg-white/10 transition-all"
        >
          Explore Our Services
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={aboutJsonLd} />
  <Footer slot="footer" />
</BaseLayout>
