---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title={`Page Not Found | ${config.site.title}`}
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <Header slot="header" />

  <!-- 404 Hero -->
  <section class="relative py-24 overflow-hidden" style="background-color: #1a2d19;">
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 30% 50%, #4a7c40, transparent 60%), radial-gradient(circle at 70% 30%, #c8a96e, transparent 50%);"></div>
    <div class="relative max-w-xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-9xl font-extrabold mb-4" style="color: #c8a96e; font-family: 'Cormorant Garamond', Georgia, serif;">404</div>
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4" style="font-family: 'Cormorant Garamond', Georgia, serif;">Page Not Found</h1>
      <p class="text-lg text-green-200 mb-10">
        Looks like this page wandered off into the garden. Let's get you back on the right path.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={base}
          class="inline-flex items-center justify-center px-8 py-4 rounded-full font-bold transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
          style="background-color: #c8a96e; color: #1a2d19;"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          Return Home
        </a>
        <a
          href={`${base}contact/`}
          class="inline-flex items-center justify-center border-2 text-white px-8 py-4 rounded-full font-semibold hover:bg-white/10 transition-all"
          style="border-color: rgba(255,255,255,0.4);"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <!-- Suggested pages -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 text-center mb-8" style="font-family: 'Cormorant Garamond', Georgia, serif;">Maybe you were looking for:</h2>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 stagger-children">
        {[
          { href: base, icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6", label: "Home" },
          { href: `${base}services/`, icon: "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z", label: "Services" },
          { href: `${base}gallery/`, icon: "M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z", label: "Gallery" },
          { href: `${base}about/`, icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z", label: "About" },
          { href: `${base}contact/`, icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z", label: "Contact" },
        ].map(page => (
          <a href={page.href} class="animate-on-scroll group p-5 bg-gray-50 rounded-3xl border border-green-100 hover:border-green-300 hover:shadow-md transition-all text-center">
            <svg class="w-8 h-8 text-green-700 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={page.icon}/></svg>
            <span class="text-sm font-semibold text-gray-900 group-hover:text-green-700 transition-colors">{page.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
