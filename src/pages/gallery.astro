---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const galleryItems = [
  { src: "7efe9fb6-b906-4cd3-aaa3-6f5d2c5d459f.jpg", caption: "Cobblestone Patio Installation", category: "Hardscaping" },
  { src: "e155339b-b8c4-4087-aec4-54e41447735a.jpg", caption: "Patio Base Preparation", category: "Hardscaping" },
  { src: "03ed4bd0-09cf-484a-b671-3ea80d3e7556.jpg", caption: "Commercial Planter — New Installation", category: "Landscaping" },
  { src: "d7761b7c-b907-4be8-8017-d3e5b741a6b4.jpg", caption: "Commercial Planter — Mixed Shrubs", category: "Landscaping" },
  { src: "11ce0f1a-bea6-4ca7-8878-f3fb8fef6bd2.jpg", caption: "Established Planter Bed", category: "Landscaping" },
  { src: "1fea5e40-0f0c-4c8d-990d-6d5ea95886df.jpg", caption: "Ground Cover Installation", category: "Landscaping" },
  { src: "2f42e893-ff78-49bc-b695-a219c3dd058e.jpg", caption: "Garden Bed Installation", category: "Landscaping" },
  { src: "61724c2c-39b8-4710-9051-eac0244e211e.jpg", caption: "Seasonal Planter Maintenance", category: "Landscaping" },
  { src: "da992e23-fc96-4640-89f0-dedd661acfa6.jpg", caption: "Lawn Aeration Service", category: "Maintenance" },
  { src: "c68acc1a-88f9-4a17-ae51-8a6adbb49e34.jpg", caption: "Yard Cleanup & Debris Removal", category: "Maintenance" },
  { src: "e3bb3112-bc50-4f9e-bf8d-b79d369c40e3.jpg", caption: "Site Work & Garden Maintenance", category: "Maintenance" },
  { src: "104d8802-ae55-4c59-83e9-6a8a4e20c064.jpg", caption: "Custom Herb Starts — Basil", category: "Plant Starts" },
  { src: "adb57937-6079-4847-95a3-8bdd9d6e5fad.jpg", caption: "Fresh Basil Ready for Transplant", category: "Plant Starts" },
  { src: "e58b601b-8b42-477a-aec7-e58ec80f45ce.jpg", caption: "Indoor Growing Setup", category: "Plant Starts" },
];

const categories = ["All", "Landscaping", "Hardscaping", "Plant Starts", "Maintenance"];
---

<BaseLayout
  title={`Gallery | ${config.site.title}`}
  description="Browse Metta Growing's project gallery — patios, garden installations, plant starts, lawn care, and commercial landscaping across the Bulkley Valley."
>
  <Header slot="header" />

  <!-- PAGE HEADER BAND -->
  <section class="py-16" style="background-color: #1a2d19;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-sm font-semibold uppercase tracking-widest" style="color: #c8a96e;">Portfolio</span>
      <h1 class="text-4xl md:text-5xl font-bold text-white mt-2" style="font-family: 'Playfair Display', serif;">
        Our Work
      </h1>
      <div class="mt-4 h-1 w-24 rounded" style="background-color: #c8a96e;"></div>
      <p class="text-green-200 mt-6 max-w-2xl text-lg">
        Real projects, real results. Browse our portfolio of landscaping, hardscaping, maintenance, and plant starts from across the Bulkley Valley.
      </p>
    </div>
  </section>

  <!-- GALLERY SECTION -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Filter buttons -->
      <div class="flex flex-wrap justify-center gap-3 mb-12 animate-on-scroll" id="filter-buttons">
        {categories.map((cat, i) => (
          <button
            data-filter={cat}
            class={`filter-btn px-5 py-2.5 rounded-full text-sm font-semibold transition-all ${i === 0 ? 'text-white active-filter' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}`}
            style={i === 0 ? 'background-color: #2d5a27;' : ''}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Gallery grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="gallery-grid">
        {galleryItems.map((item) => (
          <div
            class="gallery-item group relative overflow-hidden rounded-2xl shadow-sm border border-gray-100 cursor-pointer"
            data-category={item.category}
          >
            <div class="overflow-hidden" style="height: 280px;">
              <img
                src={`${base}assets/${item.src}`}
                alt={item.caption}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <!-- Caption overlay on hover -->
            <div class="absolute inset-0 bg-gradient-to-t from-green-950/80 via-green-950/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-5">
              <span class="text-xs font-semibold uppercase tracking-widest mb-1" style="color: #c8a96e;">{item.category}</span>
              <p class="text-white font-semibold text-base">{item.caption}</p>
            </div>
            <!-- Always visible category badge -->
            <div class="absolute top-3 left-3">
              <span class="text-xs font-semibold px-2.5 py-1 rounded-full text-white" style="background-color: rgba(26,45,25,0.85);">{item.category}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- No results state -->
      <div id="gallery-no-results" class="hidden text-center py-16">
        <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <p class="text-gray-500">No items found in this category.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background-color: #f5f0e6;" class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <h2 class="text-3xl font-bold text-green-950 mb-4" style="font-family: 'Playfair Display', serif;">
        Like What You See?
      </h2>
      <p class="text-gray-700 text-lg mb-8">
        Let's create something just as beautiful for your property. Book a free consultation and we'll get started.
      </p>
      <a
        href={`${base}contact/`}
        class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-bold text-lg transition-all shadow-sm hover:shadow-md"
        style="background-color: #2d5a27; color: white;"
      >
        Get a Free Quote
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>
  </section>

  <!-- Gallery filter script -->
  <script>
    document.addEventListener('astro:page-load', () => {
      const filterBtns = document.querySelectorAll('.filter-btn') as NodeListOf<HTMLButtonElement>;
      const galleryItems = document.querySelectorAll('.gallery-item') as NodeListOf<HTMLElement>;
      const noResults = document.getElementById('gallery-no-results');

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const filter = btn.dataset.filter || 'All';

          // Update button styles
          filterBtns.forEach(b => {
            b.classList.remove('active-filter', 'text-white');
            b.style.backgroundColor = '';
            b.classList.add('bg-gray-100', 'text-gray-600');
          });
          btn.classList.add('active-filter', 'text-white');
          btn.classList.remove('bg-gray-100', 'text-gray-600');
          btn.style.backgroundColor = '#2d5a27';

          // Filter items
          let visible = 0;
          galleryItems.forEach(item => {
            const cat = item.dataset.category || '';
            const show = filter === 'All' || cat === filter;
            item.style.display = show ? '' : 'none';
            if (show) visible++;
          });

          if (noResults) noResults.classList.toggle('hidden', visible > 0);
        });
      });
    });
  </script>

  <Footer slot="footer" />
</BaseLayout>
