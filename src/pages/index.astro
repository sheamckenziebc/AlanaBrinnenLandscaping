---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title={config.site.title}
  description="Metta Growing offers professional landscaping, lawn care, patio installation, plant starts, yard cleanup, and commercial landscaping services in Smithers and the Bulkley Valley, BC."
>
  <Header slot="header" />

  <!-- HERO SECTION -->
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <!-- Real photo background -->
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat"
      style={`background-image: url('${base}assets/7efe9fb6-b906-4cd3-aaa3-6f5d2c5d459f.jpg');`}
    ></div>
    <!-- Dark gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-green-950/90 via-green-900/75 to-green-800/50"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 w-full">
      <div class="grid lg:grid-cols-5 gap-8 items-center">
        <!-- Frosted glass hero card -->
        <div class="lg:col-span-3 backdrop-blur-sm bg-black/40 rounded-2xl p-8 md:p-12 border border-white/10 animate-on-scroll">
          <span class="inline-block text-sm font-semibold uppercase tracking-widest mb-4" style="color: #c8a96e;">Smithers, BC — Bulkley Valley</span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6" style="font-family: 'Playfair Display', serif;">
            Growing Beautiful Spaces in the Bulkley Valley
          </h1>
          <p class="text-lg md:text-xl text-green-100 leading-relaxed mb-8">
            Metta Growing brings passionate, hands-on landscaping to Smithers and surrounding communities. From lush garden installations to striking patios, we transform outdoor spaces with care rooted in this land.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={`${base}contact/`}
              class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-bold text-lg transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
              style="background-color: #c8a96e; color: #1a2d19;"
            >
              Get a Free Quote
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a
              href={`${base}gallery/`}
              class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold text-lg border-2 border-white/60 text-white hover:bg-white/10 transition-all"
            >
              View Our Work
            </a>
          </div>
        </div>
        <!-- Stats bar (desktop right column) -->
        <div class="lg:col-span-2 hidden lg:grid grid-cols-2 gap-4">
          {[
            { label: "Location", value: "Smithers, BC" },
            { label: "Experience", value: "[X+ Years]" },
            { label: "Projects Done", value: "[X+ Done]" },
            { label: "Service Area", value: "Bulkley Valley" },
          ].map((stat) => (
            <div class="backdrop-blur-sm bg-black/40 border border-white/10 rounded-xl p-5 text-center">
              <div class="text-2xl font-bold text-white" style="font-family: 'Playfair Display', serif;">{stat.value}</div>
              <div class="text-sm text-green-200 mt-1">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
      <!-- Mobile stats bar -->
      <div class="lg:hidden mt-8 grid grid-cols-2 sm:grid-cols-4 gap-3">
        {[
          { label: "Location", value: "Smithers, BC" },
          { label: "Experience", value: "[X+ Years]" },
          { label: "Projects Done", value: "[X+ Done]" },
          { label: "Service Area", value: "Bulkley Valley" },
        ].map((stat) => (
          <div class="backdrop-blur-sm bg-black/40 border border-white/10 rounded-xl p-4 text-center">
            <div class="text-xl font-bold text-white">{stat.value}</div>
            <div class="text-xs text-green-200 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section style="background-color: #f5f0e6;" class="py-12 border-b border-amber-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 stagger-children">
        {[
          {
            icon: "M3 21h18M3 7v1a3 3 0 006 0V7m0 1a3 3 0 006 0V7m0 1a3 3 0 006 0V7M3 7l.867-2.928A1 1 0 014.82 3h14.36a1 1 0 01.953.692L21 7",
            title: "Locally Owned",
            desc: "Proudly rooted in Smithers, BC"
          },
          {
            icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
            title: "Eco-Conscious",
            desc: "Sustainable practices & native plants"
          },
          {
            icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
            title: "Reliable & On-Time",
            desc: "We show up and get it done right"
          },
          {
            icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
            title: "Satisfaction Guaranteed",
            desc: "We're not done until you love it"
          },
        ].map((item) => (
          <div class="animate-on-scroll flex flex-col items-center text-center gap-3 p-4">
            <div class="w-12 h-12 bg-green-700 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-green-900">{item.title}</h3>
              <p class="text-sm text-green-700 mt-0.5">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES PREVIEW -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-sm font-semibold uppercase tracking-widest text-green-700">What We Do</span>
        <h2 class="text-4xl md:text-5xl font-bold text-green-950 mt-2 mb-4" style="font-family: 'Playfair Display', serif;">
          Full-Service Landscaping
        </h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          From first consultation to finished project, Metta Growing handles every aspect of your outdoor transformation.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
        <!-- Service Card 1: Patio & Hardscaping -->
        <div class="animate-on-scroll card-hover bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="relative h-52 overflow-hidden">
            <img
              src={`${base}assets/7efe9fb6-b906-4cd3-aaa3-6f5d2c5d459f.jpg`}
              alt="Cobblestone patio installation by Metta Growing"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-green-950/60 to-transparent"></div>
            <span class="absolute bottom-3 left-4 text-white text-sm font-semibold px-3 py-1 rounded-full" style="background-color: rgba(45,90,39,0.85);">Patio & Hardscaping</span>
          </div>
          <div class="p-8">
            <h3 class="text-xl font-bold text-green-900 mb-3" style="font-family: 'Playfair Display', serif;">Patio & Hardscaping</h3>
            <p class="text-gray-600 mb-5 leading-relaxed">Stunning paver patios, garden pathways, and stone features built to last through Bulkley Valley winters.</p>
            <ul class="space-y-2 mb-6">
              {["Paver & cobblestone installation","Custom pathway design","Proper base preparation","Finishing & sealing"].map(item => (
                <li class="flex items-center gap-2 text-sm text-gray-700">
                  <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  {item}
                </li>
              ))}
            </ul>
            <a href={`${base}services/`} class="inline-flex items-center text-green-700 font-semibold hover:text-green-900 transition-colors">
              Learn More <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Service Card 2: Lawn Care -->
        <div class="animate-on-scroll card-hover bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="relative h-52 overflow-hidden">
            <img
              src={`${base}assets/da992e23-fc96-4640-89f0-dedd661acfa6.jpg`}
              alt="Lawn aeration and maintenance service"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-green-950/60 to-transparent"></div>
            <span class="absolute bottom-3 left-4 text-white text-sm font-semibold px-3 py-1 rounded-full" style="background-color: rgba(45,90,39,0.85);">Lawn Care</span>
          </div>
          <div class="p-8">
            <h3 class="text-xl font-bold text-green-900 mb-3" style="font-family: 'Playfair Display', serif;">Lawn Care & Maintenance</h3>
            <p class="text-gray-600 mb-5 leading-relaxed">Keep your lawn healthy and green all season with regular mowing, aeration, fertilizing, and expert care.</p>
            <ul class="space-y-2 mb-6">
              {["Weekly & bi-weekly mowing","Aeration & overseeding","Fertilizing programs","Seasonal upkeep"].map(item => (
                <li class="flex items-center gap-2 text-sm text-gray-700">
                  <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  {item}
                </li>
              ))}
            </ul>
            <a href={`${base}services/`} class="inline-flex items-center text-green-700 font-semibold hover:text-green-900 transition-colors">
              Learn More <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Service Card 3: Plant Starts -->
        <div class="animate-on-scroll card-hover bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="relative h-52 overflow-hidden">
            <img
              src={`${base}assets/104d8802-ae55-4c59-83e9-6a8a4e20c064.jpg`}
              alt="Custom herb and vegetable plant starts grown under lights"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-green-950/60 to-transparent"></div>
            <span class="absolute bottom-3 left-4 text-white text-sm font-semibold px-3 py-1 rounded-full" style="background-color: rgba(45,90,39,0.85);">Plant Starts</span>
          </div>
          <div class="p-8">
            <h3 class="text-xl font-bold text-green-900 mb-3" style="font-family: 'Playfair Display', serif;">Plant Starts & Seedlings</h3>
            <p class="text-gray-600 mb-5 leading-relaxed">Indoor-grown starts for herbs, vegetables, and ornamentals — perfectly timed for northern BC's short growing season.</p>
            <ul class="space-y-2 mb-6">
              {["Herbs & vegetables","Ornamental flowers","Custom seed-starting orders","Hardy varieties for Zone 3-4"].map(item => (
                <li class="flex items-center gap-2 text-sm text-gray-700">
                  <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  {item}
                </li>
              ))}
            </ul>
            <a href={`${base}services/`} class="inline-flex items-center text-green-700 font-semibold hover:text-green-900 transition-colors">
              Learn More <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>

      <div class="text-center mt-12 animate-on-scroll">
        <a
          href={`${base}services/`}
          class="inline-flex items-center justify-center px-8 py-4 bg-green-700 text-white rounded-xl font-semibold text-lg hover:bg-green-800 transition-all shadow-sm"
        >
          View All 6 Services
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ABOUT PREVIEW -->
  <section style="background-color: #f5f0e6;" class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12 items-center">
        <!-- Photo left -->
        <div class="lg:col-span-2 animate-on-scroll">
          <div class="relative">
            <img
              src={`${base}assets/e3bb3112-bc50-4f9e-bf8d-b79d369c40e3.jpg`}
              alt="Alana Brinnen, owner of Metta Growing, at work in the garden"
              class="rounded-2xl shadow-xl w-full object-cover"
              style="height: 420px;"
              loading="lazy"
            />
            <div class="absolute -bottom-6 -right-6 bg-white rounded-2xl shadow-lg p-5 border border-gray-100">
              <div class="text-3xl font-bold text-green-700" style="font-family: 'Playfair Display', serif;">[X+]</div>
              <div class="text-sm text-gray-600 mt-1">Years Growing<br/>the Valley</div>
            </div>
          </div>
        </div>
        <!-- Text right -->
        <div class="lg:col-span-3 animate-on-scroll">
          <span class="text-sm font-semibold uppercase tracking-widest text-green-700">Our Story</span>
          <h2 class="text-4xl md:text-5xl font-bold text-green-950 mt-2 mb-6" style="font-family: 'Playfair Display', serif;">
            Rooted in Smithers,<br/>Growing with You
          </h2>
          <p class="text-lg text-gray-700 leading-relaxed mb-5">
            [2–3 sentences: how Metta Growing started and what drew Alana to landscaping. When did she start the business? What was the spark? Keep it personal and in your own voice.]
          </p>
          <p class="text-lg text-gray-700 leading-relaxed mb-5">
            [1–2 sentences: what makes your approach personal or different. What do you care most about when you take on a project? What do clients say they notice about working with you?]
          </p>
          <p class="text-lg text-gray-700 leading-relaxed mb-8">
            We know what plants survive a Bulkley Valley winter. We know the soil. We know the seasons. That's the Metta Growing difference.
          </p>
          <a
            href={`${base}about/`}
            class="inline-flex items-center justify-center px-7 py-3.5 bg-green-700 text-white rounded-xl font-semibold hover:bg-green-800 transition-all shadow-sm"
          >
            Our Full Story
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK / PROCESS -->
  <section class="py-20" style="background-color: #1a2d19;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-sm font-semibold uppercase tracking-widest" style="color: #c8a96e;">Simple Process</span>
        <h2 class="text-4xl md:text-5xl font-bold text-white mt-2" style="font-family: 'Playfair Display', serif;">
          How We Work
        </h2>
        <p class="text-green-200 mt-4 max-w-2xl mx-auto text-lg">From first conversation to finished project, we make it easy and stress-free.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 stagger-children">
        {[
          { step: "01", title: "Free Consultation", desc: "We visit your property, listen to your vision, and assess what's possible. Zero pressure, no cost." },
          { step: "02", title: "Design & Plan", desc: "We put together a clear proposal with scope, timeline, and pricing — no surprises." },
          { step: "03", title: "We Do the Work", desc: "Our crew shows up on time, works cleanly, and communicates throughout the project." },
          { step: "04", title: "You Enjoy the Results", desc: "We do a final walkthrough together. You get a beautiful outdoor space and our ongoing support." },
        ].map((item) => (
          <div class="animate-on-scroll text-center">
            <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6 border-2" style="background-color: rgba(200,169,110,0.15); border-color: #c8a96e;">
              <span class="text-xl font-bold" style="color: #c8a96e; font-family: 'Playfair Display', serif;">{item.step}</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-3" style="font-family: 'Playfair Display', serif;">{item.title}</h3>
            <p class="text-green-200 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-14 animate-on-scroll">
        <a
          href={`${base}contact/`}
          class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-bold text-lg transition-all shadow-lg"
          style="background-color: #c8a96e; color: #1a2d19;"
        >
          Book Your Free Consultation
        </a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-sm font-semibold uppercase tracking-widest text-green-700">Happy Clients</span>
        <h2 class="text-4xl md:text-5xl font-bold text-green-950 mt-2" style="font-family: 'Playfair Display', serif;">
          What Our Clients Say
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
        {[
          {
            name: "[Client first name + last initial, e.g. Sandra M.]",
            location: "[City, BC — e.g. Smithers, BC]",
            text: "[Paste a real 5-star review from a happy client. Ask past customers to share their experience — patio work, garden beds, cleanup, or lawn care all make great testimonials. Use their actual words.]",
            stars: 5
          },
          {
            name: "[Client first name + last initial]",
            location: "[City, BC]",
            text: "[Second real client testimonial. Ideally from a different service type or a different community in your service area for variety.]",
            stars: 5
          },
          {
            name: "[Client first name + last initial]",
            location: "[City, BC]",
            text: "[Third real client testimonial. Aim for range — e.g. one residential, one commercial, or one about plant starts vs. hardscaping.]",
            stars: 5
          },
        ].map((review) => (
          <div class="animate-on-scroll card-hover bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
            <div class="flex gap-1 mb-4">
              {Array(review.stars).fill(null).map(() => (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" style="color: #c8a96e;"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <blockquote class="text-gray-700 leading-relaxed mb-6 italic">"{review.text}"</blockquote>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-green-700 rounded-full flex items-center justify-center">
                <span class="text-white font-bold text-sm">{review.name.charAt(0)}</span>
              </div>
              <div>
                <div class="font-semibold text-gray-900">{review.name}</div>
                <div class="text-sm text-gray-500">{review.location}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GALLERY CTA -->
  <section style="background-color: #f5f0e6;" class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="text-sm font-semibold uppercase tracking-widest text-green-700">Our Work</span>
        <h2 class="text-4xl md:text-5xl font-bold text-green-950 mt-2 mb-4" style="font-family: 'Playfair Display', serif;">
          See What We've Built
        </h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">Browse our project portfolio from across the Bulkley Valley.</p>
      </div>

      <!-- Image mosaic -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-10 animate-on-scroll" style="grid-auto-rows: 200px;">
        <div class="col-span-2 row-span-2 overflow-hidden rounded-2xl shadow-md">
          <img src={`${base}assets/7efe9fb6-b906-4cd3-aaa3-6f5d2c5d459f.jpg`} alt="Cobblestone patio" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="overflow-hidden rounded-2xl shadow-md">
          <img src={`${base}assets/e155339b-b8c4-4087-aec4-54e41447735a.jpg`} alt="Patio base preparation" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="overflow-hidden rounded-2xl shadow-md">
