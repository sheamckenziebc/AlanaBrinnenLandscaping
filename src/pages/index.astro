---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title={config.site.title}
  description="Metta Growing offers professional landscaping, lawn care, patio installation, plant starts, yard cleanup, and commercial landscaping services in Smithers and the Bulkley Valley, BC."
>
  <Header slot="header" />

  <!-- HERO SECTION -->
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <!-- Real photo background -->
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat"
      style={`background-image: url('${base}assets/7efe9fb6-b906-4cd3-aaa3-6f5d2c5d459f.jpg');`}
    ></div>
    <!-- Gradient overlay -->
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(26,45,25,0.90), rgba(26,45,25,0.70), transparent);"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 w-full">
      <div class="grid lg:grid-cols-5 gap-8 items-center">
        <!-- Frosted glass hero card -->
        <div class="lg:col-span-3 backdrop-blur-sm rounded-3xl p-10 border animate-on-scroll" style="background-color: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.18);">
          <span class="inline-block text-sm font-semibold uppercase tracking-widest mb-4" style="color: #c8a96e; font-family: 'DM Sans', sans-serif;">Smithers, BC — Bulkley Valley</span>
          <h1 class="text-5xl md:text-6xl font-bold text-white leading-tight mb-6" style="font-family: 'Cormorant Garamond', Georgia, serif;">
            Growing Beautiful Spaces in the Bulkley Valley
          </h1>
          <span class="block italic text-green-200 text-sm border border-dashed border-white/30 rounded-xl px-4 py-3 my-2">✏️ Alana — Write 2–3 sentences describing what makes Metta Growing special. What do you want customers to know about you right away?</span>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={`${base}contact/`}
              class="inline-flex items-center justify-center px-8 py-4 rounded-full font-bold text-lg transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
              style="background-color: #c8a96e; color: #1a2d19; font-family: 'DM Sans', sans-serif;"
            >
              Get a Free Quote
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a
              href={`${base}gallery/`}
              class="inline-flex items-center justify-center px-8 py-4 rounded-full font-semibold text-lg border-2 text-white hover:bg-white/10 transition-all"
              style="border-color: rgba(255,255,255,0.6); font-family: 'DM Sans', sans-serif;"
            >
              View Our Work
            </a>
          </div>
        </div>
        <!-- Stats grid (desktop right column) -->
        <div class="lg:col-span-2 hidden lg:grid grid-cols-2 gap-4">
          {[
            { label: "Location", value: "Smithers, BC" },
            { label: "Experience", value: "✏️ [How many years?]" },
            { label: "Projects Done", value: "✏️ [Approx. # projects]" },
            { label: "Service Area", value: "Bulkley Valley" },
          ].map((stat) => (
            <div class="backdrop-blur-sm rounded-3xl p-6 text-center border" style="background-color: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.15);">
              <div class="text-2xl font-bold text-white" style="font-family: 'Cormorant Garamond', Georgia, serif;">{stat.value}</div>
              <div class="text-sm text-green-200 mt-1" style="font-family: 'DM Sans', sans-serif;">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
      <!-- Mobile stats bar -->
      <div class="lg:hidden mt-8 grid grid-cols-2 sm:grid-cols-4 gap-3">
        {[
          { label: "Location", value: "Smithers, BC" },
          { label: "Experience", value: "✏️ [How many years?]" },
          { label: "Projects Done", value: "✏️ [Approx. # projects]" },
          { label: "Service Area", value: "Bulkley Valley" },
        ].map((stat) => (
          <div class="backdrop-blur-sm rounded-3xl p-4 text-center border" style="background-color: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.15);">
            <div class="text-xl font-bold text-white" style="font-family: 'Cormorant Garamond', Georgia, serif;">{stat.value}</div>
            <div class="text-xs text-green-200 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
    </div>
  </section>

  <!-- Wave divider: dark→cream -->
  <div style="background-color: #1a2d19;" class="-mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 60L80 48C160 36 320 12 480 6C640 0 800 12 960 18C1120 24 1280 24 1360 24L1440 24V60H1360C1280 60 1120 60 960 60C800 60 640 60 480 60C320 60 160 60 80 60H0Z" fill="#f5f0e6"/>
    </svg>
  </div>

  <!-- TRUST BAR -->
  <section style="background-color: #f5f0e6;" class="py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 stagger-children">
        {[
          {
            icon: "M3 21h18M3 7v1a3 3 0 006 0V7m0 1a3 3 0 006 0V7m0 1a3 3 0 006 0V7M3 7l.867-2.928A1 1 0 014.82 3h14.36a1 1 0 01.953.692L21 7",
            title: "Locally Owned",
            desc: "Proudly rooted in Smithers, BC"
          },
          {
            icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
            title: "Eco-Conscious",
            desc: "Sustainable practices & native plants"
          },
          {
            icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
            title: "Reliable & On-Time",
            desc: "We show up and get it done right"
          },
          {
            icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
            title: "Satisfaction Guaranteed",
            desc: "We're not done until you love it"
          },
        ].map((item) => (
          <div class="animate-on-scroll rounded-2xl bg-white border border-green-100 p-6 flex flex-col items-center text-center gap-3 shadow-sm">
            <div class="w-12 h-12 bg-green-700 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-green-900">{item.title}</h3>
              <p class="text-sm text-green-700 mt-0.5">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES PREVIEW -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-sm font-semibold uppercase tracking-widest text-green-700">What We Do</span>
        <h2 class="text-4xl md:text-5xl font-bold text-green-950 mt-2 mb-4" style="font-family: 'Cormorant Garamond', Georgia, serif;">
          Full-Service Landscaping
        </h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          From first consultation to finished project, Metta Growing handles every aspect of your outdoor transformation.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
        <!-- Service Card 1: Patio & Hardscaping -->
        <div class="animate-on-scroll card-hover bg-white rounded-3xl shadow-sm border border-green-100 overflow-hidden">
          <div class="relative h-48 overflow-hidden">
            <img
              src={`${base}assets/7efe9fb6-b906-4cd3-aaa3-6f5d2c5d459f.jpg`}
              alt="Cobblestone patio installation by Metta Growing"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-green-950/60 to-transparent"></div>
            <span class="absolute bottom-3 left-4 text-white text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full" style="background-color: #c8a96e; color: #1a2d19;">Hardscaping</span>
          </div>
          <div class="p-8">
            <h3 class="text-xl font-bold text-green-900 mb-3">Patio & Hardscaping</h3>
            <p class="text-gray-600 mb-5 leading-relaxed text-sm">Stunning paver patios, garden pathways, and stone features built to last through Bulkley Valley winters.</p>
            <ul class="space-y-2 mb-6">
              <li class="text-sm text-gray-700">
                <span class="block italic text-gray-400 text-sm border border-dashed border-gray-300 rounded-xl px-4 py-3 my-2">✏️ Alana — List 4–5 things included in a patio job</span>
              </li>
            </ul>
            <p class="text-sm text-gray-500 mb-4"><span class="italic text-gray-400">✏️ Alana — What's your starting price for patio work, or do you prefer "contact for quote"?</span></p>
            <a href={`${base}services/`} class="inline-flex items-center text-green-700 font-semibold hover:text-green-900 transition-colors text-sm">
              Learn More <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Service Card 2: Landscape Installation -->
        <div class="animate-on-scroll card-hover bg-white rounded-3xl shadow-sm border border-green-100 overflow-hidden">
          <div class="relative h-48 overflow-hidden">
            <img
              src={`${base}assets/03ed4bd0-09cf-484a-b671-3ea80d3e7556.jpg`}
              alt="Commercial planter freshly installed by Metta Growing"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-green-950/60 to-transparent"></div>
            <span class="absolute bottom-3 left-4 text-white text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full" style="background-color: #c8a96e; color: #1a2d19;">Garden Design</span>
          </div>
          <div class="p-8">
            <h3 class="text-xl font-bold text-green-900 mb-3">Landscape Installation</h3>
            <p class="text-gray-600 mb-5 leading-relaxed text-sm">Custom garden beds, soil prep, and beautiful plantings chosen to thrive in our northern BC climate.</p>
            <ul class="space-y-2 mb-6">
              <li class="text-sm text-gray-700">
                <span class="block italic text-gray-400 text-sm border border-dashed border-gray-300 rounded-xl px-4 py-3 my-2">✏️ Alana — List 4–5 things included in a landscape installation job</span>
              </li>
            </ul>
            <p class="text-sm text-gray-500 mb-4"><span class="italic text-gray-400">✏️ Alana — What's your starting price for landscape installation?</span></p>
            <a href={`${base}services/`} class="inline-flex items-center text-green-700 font-semibold hover:text-green-900 transition-colors text-sm">
              Learn More <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Service Card 3: Plant Starts & Seedlings -->
        <div class="animate-on-scroll card-hover bg-white rounded-3xl shadow-sm border border-green-100 overflow-hidden">
          <div class="relative h-48 overflow-hidden">
            <img
              src={`${base}assets/104d8802-ae55-4c59-83e9-6a8a4e20c064.jpg`}
              alt="Custom herb and vegetable plant starts grown under lights"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-green-950/60 to-transparent"></div>
            <span class="absolute bottom-3 left-4 text-white text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full" style="background-color: #c8a96e; color: #1a2d19;">Growing</span>
          </div>
          <div class="p-8">
            <h3 class="text-xl font-bold text-green-900 mb-3">Plant Starts & Seedlings</h3>
            <p class="text-gray-600 mb-5 leading-relaxed text-sm">Indoor-grown starts for herbs, vegetables, and ornamentals — hardened off for northern BC's short growing season.</p>
            <ul class="space-y-2 mb-6">
              <li class="text-sm text-gray-700">
                <span class="block italic text-gray-400 text-sm border border-dashed border-gray-300 rounded-xl px-4 py-3 my-2">✏️ Alana — List 4–5 things included / varieties available for plant starts</span>
              </li>
            </ul>
            <p class="text-sm text-gray-500 mb-4"><span class="italic text-gray-400">✏️ Alana — Price per start or per flat?</span></p>
            <a href={`${base}services/`} class="inline-flex items-center text-green-700 font-semibold hover:text-green-900 transition-colors text-sm">
              Learn More <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>

      <div class="text-center mt-12 animate-on-scroll">
        <a
          href={`${base}services/`}
          class="inline-flex items-center justify-center px-8 py-4 rounded-full font-semibold text-lg transition-all shadow-sm hover:shadow-md hover:-translate-y-0.5"
          style="background-color: #c8a96e; color: #1a2d19;"
        >
          View All Services
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Wave divider: white→cream -->
  <div class="bg-white -mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 60L80 48C160 36 320 12 480 6C640 0 800 12 960 18C1120 24 1280 24 1360 24L1440 24V60H1360C1280 60 1120 60 960 60C800 60 640 60 480 60C320 60 160 60 80 60H0Z" fill="#f5f0e6"/>
    </svg>
  </div>

  <!-- ABOUT PREVIEW -->
  <section style="background-color: #f5f0e6;" class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12 items-center">
        <!-- Text left -->
        <div class="lg:col-span-3 animate-on-scroll">
          <span class="text-sm font-semibold uppercase tracking-widest text-green-700">Our Story</span>
          <h2 class="text-4xl md:text-5xl font-bold text-green-950 mt-2 mb-6" style="font-family: 'Cormorant Garamond', Georgia, serif;">
            Rooted in Smithers,<br/>Growing with You
          </h2>
          <span class="block italic text-gray-400 text-sm border border-dashed border-gray-300 rounded-xl px-4 py-3 my-2">✏️ Alana — Tell your story here. How did Metta Growing start? What drives your passion for landscaping?</span>
          <span class="block italic text-gray-400 text-sm border border-dashed border-gray-300 rounded-xl px-4 py-3 my-2">✏️ Alana — What makes your approach different from other landscapers in the area?</span>
          <a
            href={`${base}about/`}
            class="inline-flex items-center text-green-700 font-semibold hover:text-green-900 transition-colors text-lg"
          >
            Learn Our Story
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
        </div>
        <!-- Image right -->
        <div class="lg:col-span-2 animate-on-scroll">
          <div class="relative">
            <img
              src={`${base}assets/e3bb3112-bc50-4f9e-bf8d-b79d369c40e3.jpg`}
              alt="Alana Brinnen, owner of Metta Growing, at work with wheelbarrow"
              class="rounded-3xl shadow-xl w-full object-cover"
              style="height: 460px;"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave divider: cream→dark -->
  <div style="background-color: #f5f0e6;" class="-mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 0L80 12C160 24 320 48 480 54C640 60 800 48 960 42C1120 36 1280 36 1360 36L1440 36V0H1360C1280 0 1120 0 960 0C800 0 640 0 480 0C320 0 160 0 80 0H0Z" fill="#1a2d19"/>
    </svg>
  </div>

  <!-- HOW WE WORK / PROCESS -->
  <section class="py-20" style="background-color: #1a2d19;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-sm font-semibold uppercase tracking-widest" style="color: #c8a96e;">Simple Process</span>
        <h2 class="text-4xl md:text-5xl font-bold text-white mt-2" style="font-family: 'Cormorant Garamond', Georgia, serif;">
          How We Work
        </h2>
        <p class="text-green-200 mt-4 max-w-2xl mx-auto text-lg">From first conversation to finished project, we make it easy and stress-free.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 stagger-children">
        <div class="animate-on-scroll text-center">
          <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6 border-2" style="background-color: rgba(200,169,110,0.15); border-color: #c8a96e;">
            <span class="text-xl font-bold" style="color: #c8a96e; font-family: 'Cormorant Garamond', Georgia, serif;">01</span>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Free Consultation</h3>
          <p class="text-green-300 leading-relaxed text-sm"><span class="block italic text-green-300 text-sm border border-dashed border-white/30 rounded-xl px-4 py-3 my-2">✏️ Alana — Describe how your consultations work. Do you visit in person? Is there a cost?</span></p>
        </div>
        <div class="animate-on-scroll text-center">
          <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6 border-2" style="background-color: rgba(200,169,110,0.15); border-color: #c8a96e;">
            <span class="text-xl font-bold" style="color: #c8a96e; font-family: 'Cormorant Garamond', Georgia, serif;">02</span>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">We Plan Together</h3>
          <p class="text-green-300 leading-relaxed text-sm"><span class="block italic text-green-300 text-sm border border-dashed border-white/30 rounded-xl px-4 py-3 my-2">✏️ Alana — How do you provide quotes? How long does it take?</span></p>
        </div>
        <div class="animate-on-scroll text-center">
          <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6 border-2" style="background-color: rgba(200,169,110,0.15); border-color: #c8a96e;">
            <span class="text-xl font-bold" style="color: #c8a96e; font-family: 'Cormorant Garamond', Georgia, serif;">03</span>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">We Do the Work</h3>
          <p class="text-green-300 leading-relaxed text-sm"><span class="block italic text-green-300 text-sm border border-dashed border-white/30 rounded-xl px-4 py-3 my-2">✏️ Alana — What should clients expect during the work? Any details about your process?</span></p>
        </div>
        <div class="animate-on-scroll text-center">
          <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6 border-2" style="background-color: rgba(200,169,110,0.15); border-color: #c8a96e;">
            <span class="text-xl font-bold" style="color: #c8a96e; font-family: 'Cormorant Garamond', Georgia, serif;">04</span>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">You Enjoy the Results</h3>
          <p class="text-green-300 leading-relaxed text-sm"><span class="block italic text-green-300 text-sm border border-dashed border-white/30 rounded-xl px-4 py-3 my-2">✏️ Alana — How do you wrap up a job? Do you do a walkthrough? Any guarantee?</span></p>
        </div>
      </div>

      <div class="text-center mt-14 animate-on-scroll">
        <a
          href={`${base}contact/`}
          class="inline-flex items-center justify-center px-8 py-4 rounded-full font-bold text-lg transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
          style="background-color: #c8a96e; color: #1a2d19;"
        >
          Book Your Free Consultation
        </a>
      </div>
    </div>
  </section>

  <!-- Wave divider: dark→white -->
  <div style="background-color: #1a2d19;" class="-mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 60L80 48C160 36 320 12 480 6C640 0 800 12 960 18C1120 24 1280 24 1360 24L1440 24V60H1360C1280 60 1120 60 960 60C800 60 640 60 480 60C320 60 160 60 80 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- TESTIMONIALS -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-sm font-semibold uppercase tracking-widest text-green-700">Happy Clients</span>
        <h2 class="text-4xl md:text-5xl font-bold text-green-950 mt-2" style="font-family: 'Cormorant Garamond', Georgia, serif;">
          What Our Clients Say
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
        <!-- Testimonial 1 -->
