---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const templates = [
  {
    name: "Starter",
    price: "$497",
    period: "one-time",
    description: "Everything a new business needs to get online fast.",
    features: [
      "5-page responsive website",
      "Mobile-optimized design",
      "Contact form with email notifications",
      "Google Maps integration",
      "Basic SEO setup",
      "SSL certificate included",
      "1 round of revisions",
    ],
    notIncluded: [
      "Blog functionality",
      "Custom domain setup",
      "Ongoing maintenance",
    ],
    cta: "Get Started",
    popular: false,
    color: "blue"
  },
  {
    name: "Professional",
    price: "$997",
    period: "one-time",
    description: "The complete package for serious businesses ready to grow.",
    features: [
      "9-page responsive website",
      "Mobile-optimized + tablet tested",
      "Contact form with smart routing",
      "Google Maps integration",
      "Blog with 3 starter articles",
      "FAQ page with structured data",
      "Advanced SEO (Schema markup, sitemap, meta tags)",
      "Social media integration",
      "Google Analytics setup",
      "Custom domain setup",
      "2 rounds of revisions",
      "30 days of post-launch support",
    ],
    notIncluded: [
      "Monthly content updates",
    ],
    cta: "Most Popular",
    popular: true,
    color: "amber"
  },
  {
    name: "Enterprise",
    price: "$1,997",
    period: "one-time",
    description: "Full-service web presence for established businesses scaling up.",
    features: [
      "Unlimited pages",
      "Custom design to match your brand",
      "Mobile + tablet + desktop optimized",
      "Advanced contact forms with file uploads",
      "Blog with content strategy",
      "FAQ, testimonials, portfolio pages",
      "Full SEO audit and optimization",
      "Google Business Profile optimization",
      "Social media integration + sharing",
      "Analytics dashboard setup",
      "Custom domain + email setup",
      "Speed optimization (90+ Lighthouse)",
      "Unlimited revisions",
      "90 days of post-launch support",
      "Priority response time",
    ],
    notIncluded: [],
    cta: "Contact Us",
    popular: false,
    color: "blue"
  }
];

const industries = [
  { name: "General Contractors", icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" },
  { name: "Plumbers", icon: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" },
  { name: "Electricians", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "HVAC Companies", icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" },
  { name: "Roofers", icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" },
  { name: "Landscapers", icon: "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" },
  { name: "Painters", icon: "M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" },
  { name: "Auto Shops", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
];

const faqs = [
  {
    question: "What's included in the one-time price?",
    answer: "Design, development, deployment, and everything listed in your chosen tier. No monthly fees unless you opt for our hosting/maintenance add-on ($29/mo). You own the code."
  },
  {
    question: "How long does it take to build?",
    answer: "Starter: 5-7 business days. Professional: 10-14 business days. Enterprise: 3-4 weeks. We work fast because we start from proven templates, not blank screens."
  },
  {
    question: "Do I own the website?",
    answer: "100%. You get the full source code, hosting can be anywhere (we recommend GitHub Pages - it's free), and you're never locked into a contract."
  },
  {
    question: "What if I need changes later?",
    answer: "Your revision rounds are included in the price. After launch, you can make changes yourself (it's just HTML), hire any developer, or add our maintenance plan for $29/month."
  },
  {
    question: "Do you build on WordPress?",
    answer: "No. We build static sites using modern tools (Astro + Tailwind CSS). They're faster, more secure, cheaper to host, and don't need constant updates. Your site loads in under 1 second."
  },
  {
    question: "Can I see a live demo?",
    answer: "You're looking at one. This entire site is built with our Professional template. Every page, every animation, every feature you see here is included."
  }
];
---

<BaseLayout title={`Website Templates for Blue Collar Businesses | ${config.site.title}`} description="Professional website templates built for contractors, plumbers, electricians, and trades businesses. Transparent pricing. No monthly fees. Fast delivery.">
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-slate-900 via-blue-900 to-slate-800 py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center px-4 py-2 bg-amber-500/20 border border-amber-500/30 rounded-full text-amber-300 text-sm font-medium mb-6">
        No monthly fees. You own everything.
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight">
        Websites That Work <br class="hidden md:block"/><span class="text-amber-400">As Hard As You Do</span>
      </h1>
      <p class="text-xl text-blue-100 max-w-3xl mx-auto leading-relaxed mb-8">
        Professional websites built specifically for trades and blue collar businesses. No subscriptions, no page builders, no BS. Just fast, professional sites that bring in leads.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#pricing" class="inline-flex items-center justify-center bg-amber-500 text-slate-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-amber-400 transition-all shadow-lg">
          See Pricing
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
        </a>
        <a href="#demo" class="inline-flex items-center justify-center border-2 border-white/30 text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-white/10 transition-all">
          See Live Demo
        </a>
      </div>
    </div>
  </section>

  <!-- What You Get -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-blue-600 font-semibold text-sm uppercase tracking-wider">No Fluff, No Nonsense</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4">What You Actually Get</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Every site we build comes ready to bring in leads on day one.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 stagger-children">
        <div class="animate-on-scroll p-6 bg-gray-50 rounded-2xl border border-gray-100">
          <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Mobile-First</h3>
          <p class="text-sm text-gray-600">70% of your customers find you on their phone. Every site looks perfect on mobile, tablet, and desktop.</p>
        </div>
        <div class="animate-on-scroll p-6 bg-gray-50 rounded-2xl border border-gray-100">
          <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Blazing Fast</h3>
          <p class="text-sm text-gray-600">Sub-1-second load times. No bloated page builders. Static HTML that scores 90+ on Google PageSpeed.</p>
        </div>
        <div class="animate-on-scroll p-6 bg-gray-50 rounded-2xl border border-gray-100">
          <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">SEO Built In</h3>
          <p class="text-sm text-gray-600">Schema markup, meta tags, sitemaps, and structured data so Google knows exactly what you do and where.</p>
        </div>
        <div class="animate-on-scroll p-6 bg-gray-50 rounded-2xl border border-gray-100">
          <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Lead Generation</h3>
          <p class="text-sm text-gray-600">Click-to-call buttons, contact forms, sticky CTAs, and mobile call bar. Every page is built to convert visitors into calls.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Built for Blue Collar Businesses</h2>
        <p class="text-gray-600">Templates designed for the trades that build America.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {industries.map((ind) => (
          <div class="inline-flex items-center gap-2 px-4 py-2.5 bg-white rounded-full border border-gray-200 text-sm font-medium text-gray-700 hover:border-blue-300 hover:text-blue-600 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ind.icon}/></svg>
            {ind.name}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-20 bg-white" id="pricing">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-blue-600 font-semibold text-sm uppercase tracking-wider">Transparent Pricing</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4">One Price. No Surprises.</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Pay once, own forever. No monthly fees, no contracts, no nickel-and-diming.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto stagger-children">
        {templates.map((template) => (
          <div class={`animate-on-scroll relative rounded-2xl border-2 p-8 ${template.popular ? 'border-amber-400 shadow-xl scale-105 bg-white' : 'border-gray-200 bg-white'}`}>
            {template.popular && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-amber-500 text-slate-900 text-xs font-bold uppercase tracking-wider px-4 py-1.5 rounded-full">
                Most Popular
              </div>
            )}
            <div class="text-center mb-6">
              <h3 class="text-xl font-bold text-gray-900 mb-1">{template.name}</h3>
              <p class="text-sm text-gray-500 mb-4">{template.description}</p>
              <div class="flex items-baseline justify-center gap-1">
                <span class="text-4xl font-extrabold text-gray-900">{template.price}</span>
                <span class="text-sm text-gray-400">/{template.period}</span>
              </div>
            </div>

            <ul class="space-y-3 mb-8">
              {template.features.map((feature) => (
                <li class="flex items-start gap-2 text-sm">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">{feature}</span>
                </li>
              ))}
              {template.notIncluded.map((feature) => (
                <li class="flex items-start gap-2 text-sm">
                  <svg class="w-5 h-5 text-gray-300 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-400">{feature}</span>
                </li>
              ))}
            </ul>

            <a
              href={`${base}contact/`}
              class={`block w-full text-center py-3 rounded-lg font-bold transition-all ${template.popular ? 'bg-amber-500 text-slate-900 hover:bg-amber-400 shadow-md' : 'bg-gray-100 text-gray-800 hover:bg-gray-200'}`}
            >
              {template.cta}
            </a>
          </div>
        ))}
      </div>

      <p class="text-center text-sm text-gray-500 mt-8">
        All prices in USD. Optional hosting & maintenance add-on: $29/month. Free hosting available via GitHub Pages.
      </p>
    </div>
  </section>

  <!-- Live Demo -->
  <section class="py-20 bg-gray-50" id="demo">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="text-blue-600 font-semibold text-sm uppercase tracking-wider">See It In Action</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4">This Site Is the Demo</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Everything you see on this site is built with our Professional template. Navigate around. Check the mobile experience. Tap every button. This is exactly what you get.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 max-w-3xl mx-auto stagger-children">
        <a href={base} class="animate-on-scroll group p-4 bg-white rounded-xl border border-gray-200 hover:border-blue-300 hover:shadow-md transition-all text-center">
          <span class="text-sm font-semibold text-gray-900 group-hover:text-blue-600">Home Page</span>
          <span class="block text-xs text-gray-400 mt-1">Hero + Trust Bar + CTAs</span>
        </a>
        <a href={`${base}services/`} class="animate-on-scroll group p-4 bg-white rounded-xl border border-gray-200 hover:border-blue-300 hover:shadow-md transition-all text-center">
          <span class="text-sm font-semibold text-gray-900 group-hover:text-blue-600">Services</span>
          <span class="block text-xs text-gray-400 mt-1">Cards + Process Steps</span>
        </a>
        <a href={`${base}about/`} class="animate-on-scroll group p-4 bg-white rounded-xl border border-gray-200 hover:border-blue-300 hover:shadow-md transition-all text-center">
          <span class="text-sm font-semibold text-gray-900 group-hover:text-blue-600">About</span>
          <span class="block text-xs text-gray-400 mt-1">Story + Team + Values</span>
        </a>
        <a href={`${base}contact/`} class="animate-on-scroll group p-4 bg-white rounded-xl border border-gray-200 hover:border-blue-300 hover:shadow-md transition-all text-center">
          <span class="text-sm font-semibold text-gray-900 group-hover:text-blue-600">Contact</span>
          <span class="block text-xs text-gray-400 mt-1">Form + Map + Info</span>
        </a>
        <a href={`${base}blog/`} class="animate-on-scroll group p-4 bg-white rounded-xl border border-gray-200 hover:border-blue-300 hover:shadow-md transition-all text-center">
          <span class="text-sm font-semibold text-gray-900 group-hover:text-blue-600">Blog</span>
          <span class="block text-xs text-gray-400 mt-1">Article Cards + Newsletter</span>
        </a>
        <a href={`${base}faq/`} class="animate-on-scroll group p-4 bg-white rounded-xl border border-gray-200 hover:border-blue-300 hover:shadow-md transition-all text-center">
          <span class="text-sm font-semibold text-gray-900 group-hover:text-blue-600">FAQ</span>
          <span class="block text-xs text-gray-400 mt-1">Accordion + Schema</span>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Common Questions</h2>
      </div>

      <div class="space-y-4">
        {faqs.map((faq, index) => (
          <details class="group bg-gray-50 rounded-2xl border border-gray-200 overflow-hidden" open={index === 0}>
            <summary class="flex items-center justify-between cursor-pointer px-6 py-5 text-left font-semibold text-gray-900 hover:text-blue-600 transition-colors list-none [&::-webkit-details-marker]:hidden">
              <span class="pr-4">{faq.question}</span>
              <svg class="w-5 h-5 text-gray-400 flex-shrink-0 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 leading-relaxed border-t border-gray-200 pt-4">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="relative py-20 bg-gradient-to-br from-blue-700 to-blue-900 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.2&quot; fill-rule=&quot;evenodd&quot;%3E%3Cpath d=&quot;M0 40L40 0H20L0 20M40 40V20L20 40&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Your Competition Already Has a Website.
      </h2>
      <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
        Stop losing jobs to businesses with better Google presence. Get a professional site that works 24/7 to bring you leads.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${base}contact/`}
          class="inline-flex items-center justify-center bg-amber-500 text-slate-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-amber-400 transition-all shadow-lg"
        >
          Get Started Today
        </a>
        <a
          href="#pricing"
          class="inline-flex items-center justify-center border-2 border-white text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-white/10 transition-all"
        >
          Compare Plans
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
