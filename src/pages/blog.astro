---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const articles = [
  {
    title: "Choosing Plants That Survive Smithers Winters",
    excerpt: "Zone 3-4 gardening doesn't mean boring. We break down the best cold-hardy perennials, ornamental grasses, and flowering shrubs that thrive through Bulkley Valley winters — and look incredible doing it.",
    date: "March 15, 2025",
    category: "Plant Selection",
    readTime: "6 min read",
    image: "1fea5e40-0f0c-4c8d-990d-6d5ea95886df.jpg",
    imageAlt: "Ground cover plants in a lush Smithers garden bed"
  },
  {
    title: "Spring Yard Cleanup: Your Bulkley Valley Checklist",
    excerpt: "When the snow finally melts in Smithers, there's a short window to get your yard ready for the growing season. Here's our practical checklist for a thorough spring cleanup that sets your property up for success.",
    date: "April 2, 2025",
    category: "Seasonal Tips",
    readTime: "5 min read",
    image: "c68acc1a-88f9-4a17-ae51-8a6adbb49e34.jpg",
    imageAlt: "Truck loaded with yard debris during spring cleanup"
  },
  {
    title: "Why Local Plant Starts Beat Store-Bought Seedlings",
    excerpt: "Those bright seedlings at the hardware store look tempting, but they're often grown in southern greenhouses and haven't been hardened for our climate. Here's why locally grown starts give you a real head start.",
    date: "April 28, 2025",
    category: "Growing Tips",
    readTime: "4 min read",
    image: "104d8802-ae55-4c59-83e9-6a8a4e20c064.jpg",
    imageAlt: "Basil seedlings growing under grow lights in Smithers"
  }
];
---

<BaseLayout
  title={`Blog | ${config.site.title}`}
  description="Landscaping tips, plant guides, and seasonal advice for Smithers and the Bulkley Valley from Metta Growing."
>
  <Header slot="header" />

  <!-- PAGE HEADER BAND -->
  <section class="py-20" style="background-color: #1a2d19;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-sm font-semibold uppercase tracking-widest" style="color: #c8a96e;">Insights & Tips</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mt-3 mb-4" style="font-family: 'Cormorant Garamond', Georgia, serif;">
        Growing Knowledge
      </h1>
      <p class="text-green-200 max-w-2xl text-lg">Tips, guides, and seasonal advice for Bulkley Valley gardeners</p>
      <div class="mt-5 h-1 w-24 rounded" style="background-color: #c8a96e;"></div>
    </div>
  </section>

  <!-- Wave divider: dark→white -->
  <div style="background-color: #1a2d19;" class="-mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 60L80 48C160 36 320 12 480 6C640 0 800 12 960 18C1120 24 1280 24 1360 24L1440 24V60H1360C1280 60 1120 60 960 60C800 60 640 60 480 60C320 60 160 60 80 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- ARTICLES -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
        {articles.map((article) => (
          <article class="animate-on-scroll group bg-white rounded-3xl border border-green-100 shadow-sm overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 card-hover">
            <div class="relative h-52 overflow-hidden">
              <img
                src={`${base}assets/${article.image}`}
                alt={article.imageAlt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-green-950/50 to-transparent"></div>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full" style="color: #1a2d19; background-color: #c8a96e;">{article.category}</span>
                <span class="text-xs text-gray-400">{article.readTime}</span>
              </div>
              <h2 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-green-700 transition-colors" style="font-family: 'Cormorant Garamond', Georgia, serif;">{article.title}</h2>
              <p class="text-gray-600 text-sm leading-relaxed mb-4">{article.excerpt}</p>
              <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                <span class="text-xs text-gray-400">{article.date}</span>
                <span class="text-sm font-semibold text-green-700 inline-flex items-center group-hover:gap-2 transition-all">
                  Read More
                  <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </span>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="text-center mt-12 animate-on-scroll">
        <p class="text-gray-500 text-lg">More articles coming throughout the season. Check back for new tips on landscaping in the Bulkley Valley.</p>
      </div>
    </div>
  </section>

  <!-- CTA section -->
  <section style="background-color: #f5f0e6;" class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <h3 class="text-2xl font-bold text-green-950 mb-3">Have a gardening question?</h3>
      <p class="text-gray-600 mb-8">Whether you're planning a new project or troubleshooting your garden, Alana is happy to chat. Reach out any time.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={`${base}contact/`} class="inline-flex items-center justify-center px-8 py-4 rounded-full font-semibold transition-colors shadow-sm hover:shadow-md hover:-translate-y-0.5" style="background-color: #c8a96e; color: #1a2d19;">
          Ask a Question
        </a>
        <a href={`${base}faq/`} class="inline-flex items-center justify-center px-8 py-4 rounded-full font-semibold border-2 transition-colors" style="border-color: #2d5a27; color: #2d5a27;">
          Browse FAQ
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
