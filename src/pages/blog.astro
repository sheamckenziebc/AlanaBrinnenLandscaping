---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const articles = [
  {
    title: "Choosing Plants That Survive Smithers Winters",
    excerpt: "Northern BC winters are no joke — temperatures can dip below -30°C in the Bulkley Valley. Here's our guide to the hardy perennials, shrubs, and ground covers that will come back year after year in Smithers-area gardens.",
    date: "December 10, 2024",
    category: "Plant Selection",
    readTime: "6 min read",
    image: "61724c2c-39b8-4710-9051-eac0244e211e.jpg",
    imageAlt: "Truck beside flowering shrubs in the Bulkley Valley"
  },
  {
    title: "Spring Yard Cleanup: Your Bulkley Valley Checklist",
    excerpt: "After a long northern BC winter, your yard needs some serious attention before the growing season begins. Follow this room-by-room checklist to get your property looking its best before the May long weekend.",
    date: "March 3, 2025",
    category: "Seasonal Tips",
    readTime: "5 min read",
    image: "c68acc1a-88f9-4a17-ae51-8a6adbb49e34.jpg",
    imageAlt: "Debris removal and spring yard cleanup"
  },
  {
    title: "Why Local Plant Starts Beat Store-Bought Seedlings",
    excerpt: "Big box store seedlings are often grown in southern BC or even California — they're not acclimated to our climate and often struggle to transplant well. Here's why locally-grown starts make a real difference in your garden's success.",
    date: "April 14, 2025",
    category: "Growing Tips",
    readTime: "4 min read",
    image: "104d8802-ae55-4c59-83e9-6a8a4e20c064.jpg",
    imageAlt: "Locally grown basil seedlings under grow lights at Metta Growing"
  }
];
---

<BaseLayout
  title={`Blog | ${config.site.title}`}
  description="Landscaping tips, plant guides, and seasonal advice for Smithers and the Bulkley Valley from Metta Growing."
>
  <Header slot="header" />

  <!-- PAGE HEADER BAND -->
  <section class="py-16" style="background-color: #1a2d19;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-sm font-semibold uppercase tracking-widest" style="color: #c8a96e;">Insights & Tips</span>
      <h1 class="text-4xl md:text-5xl font-bold text-white mt-2" style="font-family: 'Playfair Display', serif;">
        The Metta Growing Blog
      </h1>
      <div class="mt-4 h-1 w-24 rounded" style="background-color: #c8a96e;"></div>
      <p class="text-green-200 mt-6 max-w-2xl text-lg">
        Practical landscaping advice written for northern BC gardeners and property owners.
      </p>
    </div>
  </section>

  <!-- ARTICLES -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Category filter -->
      <div class="flex flex-wrap justify-center gap-2 mb-12 animate-on-scroll">
        <button class="px-4 py-2 text-sm font-semibold rounded-full text-white" style="background-color: #2d5a27;">All</button>
        <button class="px-4 py-2 text-sm font-medium rounded-full bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors">Plant Selection</button>
        <button class="px-4 py-2 text-sm font-medium rounded-full bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors">Seasonal Tips</button>
        <button class="px-4 py-2 text-sm font-medium rounded-full bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors">Growing Tips</button>
        <button class="px-4 py-2 text-sm font-medium rounded-full bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors">Hardscaping</button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
        {articles.map((article) => (
          <article class="animate-on-scroll group bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 card-hover">
            <div class="relative h-52 overflow-hidden">
              <img
                src={`${base}assets/${article.image}`}
                alt={article.imageAlt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-green-950/50 to-transparent"></div>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-semibold uppercase tracking-wider px-2 py-1 rounded" style="color: #2d5a27; background-color: #f5f0e6;">{article.category}</span>
                <span class="text-xs text-gray-400">{article.readTime}</span>
              </div>
              <h2 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-green-700 transition-colors" style="font-family: 'Playfair Display', serif;">{article.title}</h2>
              <p class="text-gray-600 text-sm leading-relaxed mb-4">{article.excerpt}</p>
              <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                <span class="text-xs text-gray-400">{article.date}</span>
                <span class="text-sm font-semibold text-green-700 inline-flex items-center">
                  Read More
                  <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </span>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="text-center mt-12 animate-on-scroll">
        <p class="text-gray-500">More articles coming throughout the season. Check back for new tips on landscaping in the Bulkley Valley.</p>
      </div>
    </div>
  </section>

  <!-- CTA section -->
  <section style="background-color: #f5f0e6;" class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <div class="bg-white rounded-2xl border border-gray-200 p-8 md:p-12 shadow-sm">
        <div class="w-12 h-12 bg-green-700 rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        </div>
        <h2 class="text-2xl font-bold text-green-950 mb-2" style="font-family: 'Playfair Display', serif;">Have a Landscaping Question?</h2>
        <p class="text-gray-600 mb-6">Whether you're planning a new project or troubleshooting your garden, Alana is happy to chat. Reach out any time.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href={`${base}contact/`} class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-semibold text-white hover:bg-green-800 transition-colors" style="background-color: #2d5a27;">
            Ask a Question
          </a>
          <a href={`${base}faq/`} class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-semibold border-2 transition-colors" style="border-color: #2d5a27; color: #2d5a27;">
            Browse FAQ
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
